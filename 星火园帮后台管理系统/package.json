{
  "name": "xinghuoyuanbang",
  "version": "1.0.0",
  "description": "星火园帮后台管理系统",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "logs:view": "tail -f logs/combined-$(date +%Y-%m-%d).log",
    "logs:error": "tail -f logs/error-$(date +%Y-%m-%d).log",
    "monitor:db": "node scripts/monitor-db-pool.js",
    "test:auto-approval": "node scripts/test-auto-rider-approval.js",
    "test:quick-approval": "node scripts/quick-test-auto-approval.js",
    "diagnose:approval": "node scripts/diagnose-auto-approval.js",
    "fix-system-message-enum": "node scripts/fix-system-message-enum.js",
    "fix:payment-status": "node scripts/fix-payment-status.js",
