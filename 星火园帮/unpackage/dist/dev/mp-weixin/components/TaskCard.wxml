<view data-event-opts="{{[['tap',[['handleCardClick',['$event']]]]]}}" class="task-card data-v-49f80010" bindtap="__e"><view class="card-header data-v-49f80010"><view class="publisher-info data-v-49f80010"><image class="publisher-avatar my-image data-v-49f80010" src="{{publisherAvatar}}" mode="aspectFill"></image><text class="publisher-name my-text data-v-49f80010">{{publisherName}}</text></view><view class="{{['task-status','data-v-49f80010',statusClass]}}">{{''+formattedStatus+''}}</view></view><view class="card-body data-v-49f80010"><text class="task-title my-text data-v-49f80010">{{task.title||"无标题"}}</text><view class="task-meta data-v-49f80010"><block wx:if="{{formattedDeadline}}"><text class="task-deadline data-v-49f80010"><text class="deadline-icon data-v-49f80010">⏰</text>{{''+formattedDeadline+' 截止'}}</text></block></view><text class="task-description my-text data-v-49f80010">{{formattedDescription}}</text><view class="task-tags-section data-v-49f80010"><block wx:if="{{task.taskType}}"><text class="tag task-type-tag my-text data-v-49f80010">{{''+task.taskType+''}}</text></block><block wx:if="{{task.locationText}}"><text class="tag location-tag my-text data-v-49f80010">{{''+$root.m0+''}}</text></block><block wx:if="{{task.category}}"><text class="tag category-tag my-text data-v-49f80010">{{''+task.category+''}}</text></block><block wx:for="{{task.tags}}" wx:for-item="tag" wx:for-index="__i0__" wx:key="*this"><text class="tag general-tag my-text data-v-49f80010">{{''+tag+''}}</text></block></view></view><view class="card-footer data-v-49f80010"><view class="task-reward data-v-49f80010"><text class="reward-icon my-text data-v-49f80010">💰</text><text class="reward-amount my-text data-v-49f80010">{{formattedReward}}</text></view><view class="task-time data-v-49f80010"><text class="data-v-49f80010">{{formattedPublishTime}}</text></view></view></view>