/* ---- 通用辅助类 ---- */
.card.data-v-ed732dc8 {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0px 2px 8px rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}
.rounded-sm.data-v-ed732dc8 {
  border-radius: 4rpx !important;
}
.rounded-base.data-v-ed732dc8 {
  border-radius: 8rpx !important;
}
.rounded-lg.data-v-ed732dc8 {
  border-radius: 16rpx !important;
}
.rounded-circle.data-v-ed732dc8 {
  border-radius: 50% !important;
}
.rounded-pill.data-v-ed732dc8 {
