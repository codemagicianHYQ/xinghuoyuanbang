}
.shadow-lg.data-v-47b4a9d0 {
  box-shadow: 0px 4px 16px rgba(0, 0, 0, 0.12) !important;
}
/* 页面容器基础样式 */
.page-container.data-v-47b4a9d0 {
  min-height: 100vh;
  background-color: #f8f8f8;
  box-sizing: border-box;
  padding: 16rpx;
}
/* ---- 通用按钮样式 ---- */
.button-error.data-v-47b4a9d0, .button-primary.data-v-47b4a9d0 {
  font-size: 32rpx;
  padding: 18rpx 30rpx;
  border-radius: 1000px;
  text-align: center;
  line-height: 1.5;
  border: none;
  transition: background-color 0.2s ease, opacity 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}
.button-error.data-v-47b4a9d0:active, .button-primary.data-v-47b4a9d0:active {
  opacity: 0.8;
}
.disabled.button-error.data-v-47b4a9d0, .disabled.button-primary.data-v-47b4a9d0 {
  opacity: 0.6 !important;
  cursor: not-allowed;
  box-shadow: none;
}
.button-primary.data-v-47b4a9d0 {
  background-color: #007aff;
  color: #ffffff;
}
.button-primary.data-v-47b4a9d0:active {
  background-color: #0062cc;
}
.button-primary.disabled.data-v-47b4a9d0 {
  background-color: #66afff !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
.button-error.data-v-47b4a9d0 {
  background-color: #dd524d;
  color: #ffffff;
}
.button-error.data-v-47b4a9d0:active {
  background-color: #cf2d28;
}
.button-error.disabled.data-v-47b4a9d0 {
  background-color: #eda5a3 !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
