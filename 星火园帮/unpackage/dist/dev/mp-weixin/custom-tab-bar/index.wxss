/* ---- 通用辅助类 ---- */
.card.data-v-47b4a9d0 {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0px 2px 8px rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}
.rounded-sm.data-v-47b4a9d0 {
  border-radius: 4rpx !important;
}
.rounded-base.data-v-47b4a9d0 {
  border-radius: 8rpx !important;
}
.rounded-lg.data-v-47b4a9d0 {
  border-radius: 16rpx !important;
}
.rounded-circle.data-v-47b4a9d0 {
  border-radius: 50% !important;
}
.rounded-pill.data-v-47b4a9d0 {
  border-radius: 1000px !important;
}
.shadow-sm.data-v-47b4a9d0 {
  box-shadow: 0px 1px 4px rgba(0, 0, 0, 0.06) !important;
}
.shadow-base.data-v-47b4a9d0 {
