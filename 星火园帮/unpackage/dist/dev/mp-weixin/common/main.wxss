/* ---- 通用辅助类 ---- */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0px 2px 8px rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}
.rounded-sm {
  border-radius: 4rpx !important;
}
.rounded-base {
  border-radius: 8rpx !important;
}
.rounded-lg {
  border-radius: 16rpx !important;
}
.rounded-circle {
  border-radius: 50% !important;
}
.rounded-pill {
  border-radius: 1000px !important;
}
.shadow-sm {
  box-shadow: 0px 1px 4px rgba(0, 0, 0, 0.06) !important;
}
.shadow-base {
  box-shadow: 0px 2px 8px rgba(0, 0, 0, 0.08) !important;
}
.shadow-lg {
  box-shadow: 0px 4px 16px rgba(0, 0, 0, 0.12) !important;
}
/* 页面容器基础样式 */
.page-container {
  min-height: 100vh;
  background-color: #f8f8f8;
  box-sizing: border-box;
  padding: 16rpx;
}
/* ---- 通用按钮样式 ---- */
.button-primary, .button-error {
  font-size: 32rpx;
  padding: 18rpx 30rpx;
  border-radius: 1000px;
  text-align: center;
  line-height: 1.5;
  border: none;
  transition: background-color 0.2s ease, opacity 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}
.button-primary:active, .button-error:active {
  opacity: 0.8;
}
.disabled.button-primary, .disabled.button-error {
  opacity: 0.6 !important;
  cursor: not-allowed;
  box-shadow: none;
}
.button-primary {
  background-color: #007aff;
  color: #ffffff;
}
.button-primary:active {
  background-color: #0062cc;
}
.button-primary.disabled {
  background-color: #66afff !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
.button-error {
  background-color: #dd524d;
  color: #ffffff;
}
.button-error:active {
  background-color: #cf2d28;
}
.button-error.disabled {
  background-color: #eda5a3 !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
/* ---- 你可以在下方继续添加项目中其他自定义的全局 SASS 变量或通用样式 ---- */
.fun-title {
  font-family: "ZCOOL KuaiLe", "Smiley Sans", "PingFang SC", "Microsoft YaHei", Arial, sans-serif !important;
  font-weight: bold;
  font-size: 36rpx;
  color: #222;
  letter-spacing: 2rpx;
  line-height: 1.2;
}
.fun-announcement {
  font-family: "ZCOOL KuaiLe", "Smiley Sans", "PingFang SC", "Microsoft YaHei", Arial, sans-serif !important;
  font-size: 28rpx;
  color: #222;
  font-weight: bold;
  letter-spacing: 1.5rpx;
}
.fun-tab-label {
  font-family: "ZCOOL KuaiLe", "Smiley Sans", "PingFang SC", "Microsoft YaHei", Arial, sans-serif !important;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
