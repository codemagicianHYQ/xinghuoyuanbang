/* ---- 通用辅助类 ---- */
.card.data-v-d5ac5b5c {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0px 2px 8px rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}
.rounded-sm.data-v-d5ac5b5c {
  border-radius: 4rpx !important;
}
.rounded-base.data-v-d5ac5b5c {
  border-radius: 8rpx !important;
}
.rounded-lg.data-v-d5ac5b5c {
  border-radius: 16rpx !important;
}
.rounded-circle.data-v-d5ac5b5c {
  border-radius: 50% !important;
}
.rounded-pill.data-v-d5ac5b5c {
  border-radius: 1000px !important;
}
.shadow-sm.data-v-d5ac5b5c {
  box-shadow: 0px 1px 4px rgba(0, 0, 0, 0.06) !important;
}
.shadow-base.data-v-d5ac5b5c {
  box-shadow: 0px 2px 8px rgba(0, 0, 0, 0.08) !important;
}
.shadow-lg.data-v-d5ac5b5c {
  box-shadow: 0px 4px 16px rgba(0, 0, 0, 0.12) !important;
}
/* 页面容器基础样式 */
.page-container.data-v-d5ac5b5c {
  min-height: 100vh;
  background-color: #f8f8f8;
  box-sizing: border-box;
  padding: 16rpx;
}
/* ---- 通用按钮样式 ---- */
.button-primary.data-v-d5ac5b5c, .button-error.data-v-d5ac5b5c {
  font-size: 32rpx;
  padding: 18rpx 30rpx;
  border-radius: 1000px;
  text-align: center;
  line-height: 1.5;
  border: none;
  transition: background-color 0.2s ease, opacity 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}
.button-primary.data-v-d5ac5b5c:active, .button-error.data-v-d5ac5b5c:active {
  opacity: 0.8;
}
.disabled.button-primary.data-v-d5ac5b5c, .disabled.button-error.data-v-d5ac5b5c {
  opacity: 0.6 !important;
  cursor: not-allowed;
  box-shadow: none;
}
.button-primary.data-v-d5ac5b5c {
  background-color: #007aff;
  color: #ffffff;
}
.button-primary.data-v-d5ac5b5c:active {
  background-color: #0062cc;
}
.button-primary.disabled.data-v-d5ac5b5c {
  background-color: #66afff !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
.button-error.data-v-d5ac5b5c {
  background-color: #dd524d;
  color: #ffffff;
}
.button-error.data-v-d5ac5b5c:active {
  background-color: #cf2d28;
}
.button-error.disabled.data-v-d5ac5b5c {
  background-color: #eda5a3 !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
/* ---- 你可以在下方继续添加项目中其他自定义的全局 SASS 变量或通用样式 ---- */
.fun-title.data-v-d5ac5b5c {
  font-family: "ZCOOL KuaiLe", "Smiley Sans", "PingFang SC", "Microsoft YaHei", Arial, sans-serif !important;
