.resources-container.data-v-d5ac5b5c {
  min-height: 100vh;
  background: linear-gradient(135deg, #ffeef8 0%, #e0f2fe 50%, #f0f9ff 100%);
  padding-bottom: 100rpx;
  position: relative;
}
.resources-container.data-v-d5ac5b5c::before {
  content: "";
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(to top, rgba(255, 182, 193, 0.15) 0%, rgba(135, 206, 250, 0.1) 50%, transparent 100%);
  pointer-events: none;
  z-index: 0;
}
.search-section.data-v-d5ac5b5c {
  padding: 16rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.9) 100%);
  -webkit-backdrop-filter: blur(10rpx);
          backdrop-filter: blur(10rpx);
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.search-bar.data-v-d5ac5b5c {
  position: relative;
  display: flex;
  align-items: center;
}
.search-input.data-v-d5ac5b5c {
  flex: 1;
  height: 72rpx;
  background-color: #f8f8f8;
  border-radius: 36rpx;
  padding: 0 80rpx 0 32rpx;
  font-size: 28rpx;
}
.search-icon.data-v-d5ac5b5c {
  position: absolute;
  right: 24rpx;
  font-size: 32rpx;
}
.resource-categories.data-v-d5ac5b5c {
  padding: 16rpx;
  position: relative;
  z-index: 1;
}
.category-card.data-v-d5ac5b5c {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  position: relative;
  overflow: visible;
  border: 1px solid rgba(255, 255, 255, 0.8);
  -webkit-transform: translateY(0) translateZ(0);
          transform: translateY(0) translateZ(0);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12), 0 4rpx 8rpx rgba(0, 0, 0, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}
.category-card.data-v-d5ac5b5c::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #4facfe 0%, #00f2fe 100%);
  border-radius: 16rpx 0 0 16rpx;
  transition: width 0.3s ease, box-shadow 0.3s ease;
  z-index: 1;
}
.category-card.data-v-d5ac5b5c::after {
  content: "";
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  z-index: 1;
}
.category-card.data-v-d5ac5b5c:hover {
  -webkit-transform: translateY(-8rpx) translateZ(0);
          transform: translateY(-8rpx) translateZ(0);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.16), 0 8rpx 16rpx rgba(0, 0, 0, 0.12), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}
.category-card.data-v-d5ac5b5c:active {
  -webkit-transform: translateY(-4rpx) scale(0.98) translateZ(0);
          transform: translateY(-4rpx) scale(0.98) translateZ(0);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.14), 0 6rpx 12rpx rgba(0, 0, 0, 0.1), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}
.category-card.data-v-d5ac5b5c:active::before {
  width: 8rpx;
}
.category-card.data-v-d5ac5b5c:active::after {
  -webkit-transform: scale(1.2);
          transform: scale(1.2);
  opacity: 0.8;
}
.exam-card.data-v-d5ac5b5c::before {
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 0 16rpx rgba(102, 126, 234, 0.5), 0 0 8rpx rgba(102, 126, 234, 0.3);
}
.exam-card.data-v-d5ac5b5c::after {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.3) 0%, rgba(118, 75, 162, 0.3) 100%);
}
.exam-card.data-v-d5ac5b5c:hover {
  box-shadow: 0 20rpx 48rpx rgba(102, 126, 234, 0.3), 0 12rpx 24rpx rgba(102, 126, 234, 0.2), 0 6rpx 12rpx rgba(102, 126, 234, 0.15), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  border-color: rgba(102, 126, 234, 0.3);
}
.exam-card.data-v-d5ac5b5c:active {
