<view class="publish-paperwork-container page-container data-v-50d9f1a2"><view class="header-decoration data-v-50d9f1a2"><view class="main-icon data-v-50d9f1a2">📋</view><view class="title-content data-v-50d9f1a2"><view class="page-title data-v-50d9f1a2">发布求资料</view><view class="page-subtitle data-v-50d9f1a2">专业资料，高效获取！</view></view></view><form data-event-opts="{{[['submit',[['submitPaperworkRequest',['$event']]]]]}}" bindsubmit="__e" class="data-v-50d9f1a2"><view class="form-section card rounded-lg shadow-base data-v-50d9f1a2"><view class="form-item data-v-50d9f1a2"><text class="item-label data-v-50d9f1a2"> 资料名称 <text class="required-star data-v-50d9f1a2">*</text></text><input class="input-field rounded-base data-v-50d9f1a2" placeholder="请输入您需要的资料名称" maxlength="50" data-event-opts="{{[['input',[['__set_model',['$0','title','$event',[]],['formData']]]]]}}" value="{{formData.title}}" bindinput="__e"/></view><view class="form-item data-v-50d9f1a2"><text class="item-label data-v-50d9f1a2"> 资料类型 <text class="required-star data-v-50d9f1a2">*</text></text><picker range="{{materialTypes}}" data-event-opts="{{[['change',[['bindMaterialTypeChange',['$event']]]]]}}" bindchange="__e" class="data-v-50d9f1a2"><view class="picker-value input-imitation rounded-base data-v-50d9f1a2">{{''+(formData.materialType||"请选择资料类型")+''}}<text class="uni-icon uni-icon-arrowdown picker-arrow data-v-50d9f1a2"></text></view></picker></view><view class="form-item data-v-50d9f1a2"><text class="item-label data-v-50d9f1a2"> 详细描述 <text class="required-star data-v-50d9f1a2">*</text></text><textarea class="textarea-field rounded-base data-v-50d9f1a2" placeholder="请详细描述您需要的资料内容、格式等信息...." maxlength="500" data-event-opts="{{[['input',[['__set_model',['$0','description','$event',[]],['formData']]]]]}}" value="{{formData.description}}" bindinput="__e"></textarea></view><view class="form-item data-v-50d9f1a2"><text class="item-label data-v-50d9f1a2"> 价格 (元) <text class="required-star data-v-50d9f1a2">*</text></text><input class="input-field rounded-base data-v-50d9f1a2" type="digit" placeholder="建议金额2元以上" data-event-opts="{{[['input',[['__set_model',['$0','reward','$event',[]],['formData']],['validatePrice',['$event']]]]]}}" value="{{formData.reward}}" bindinput="__e"/></view><view class="form-item data-v-50d9f1a2"><text class="item-label data-v-50d9f1a2"> 资料形式 <text class="required-star data-v-50d9f1a2">*</text></text><picker range="{{materialFormats}}" data-event-opts="{{[['change',[['bindMaterialFormatChange',['$event']]]]]}}" bindchange="__e" class="data-v-50d9f1a2"><view class="picker-value input-imitation rounded-base data-v-50d9f1a2">{{''+(formData.materialFormat||"请选择资料形式")+''}}<text class="uni-icon uni-icon-arrowdown picker-arrow data-v-50d9f1a2"></text></view></picker></view><view class="form-item data-v-50d9f1a2"><text class="item-label data-v-50d9f1a2"> 交易地点 </text><input class="input-field rounded-base data-v-50d9f1a2" placeholder="请选择交易地点（电子资料可网上发）" maxlength="100" data-event-opts="{{[['input',[['__set_model',['$0','tradeLocation','$event',[]],['formData']]]]]}}" value="{{formData.tradeLocation}}" bindinput="__e"/><view class="address-actions data-v-50d9f1a2"><text data-event-opts="{{[['tap',[['selectSavedAddress',['$event']]]]]}}" class="action-link data-v-50d9f1a2" bindtap="__e">选择常用地址</text><text data-event-opts="{{[['tap',[['chooseMapLocation',['$event']]]]]}}" class="action-link data-v-50d9f1a2" bindtap="__e">地图选择</text></view><block wx:if="{{formData.materialFormat==='电子资料'}}"><text class="format-tip data-v-50d9f1a2"> 接单后在订单页面联系接单员发送联系方式 </text></block></view></view><view data-event-opts="{{[['tap',[['submitPaperworkRequest',['$event']]]]]}}" class="submit-btn paperwork-btn rounded-full data-v-50d9f1a2" bindtap="__e"><text class="btn-icon data-v-50d9f1a2">🚀</text><text class="btn-text data-v-50d9f1a2">立即发布</text></view></form></view>