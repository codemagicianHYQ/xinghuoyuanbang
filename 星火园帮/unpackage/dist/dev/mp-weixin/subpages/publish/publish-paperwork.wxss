  box-sizing: border-box;
  padding: 16rpx;
}
/* ---- 通用按钮样式 ---- */
.button-primary.data-v-50d9f1a2, .button-error.data-v-50d9f1a2 {
  font-size: 32rpx;
  padding: 18rpx 30rpx;
  border-radius: 1000px;
  text-align: center;
  line-height: 1.5;
  border: none;
  transition: background-color 0.2s ease, opacity 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}
.button-primary.data-v-50d9f1a2:active, .button-error.data-v-50d9f1a2:active {
  opacity: 0.8;
}
.disabled.button-primary.data-v-50d9f1a2, .disabled.button-error.data-v-50d9f1a2 {
  opacity: 0.6 !important;
  cursor: not-allowed;
  box-shadow: none;
}
.button-primary.data-v-50d9f1a2 {
  background-color: #007aff;
  color: #ffffff;
}
.button-primary.data-v-50d9f1a2:active {
  background-color: #0062cc;
}
.button-primary.disabled.data-v-50d9f1a2 {
  background-color: #66afff !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
.button-error.data-v-50d9f1a2 {
  background-color: #dd524d;
  color: #ffffff;
}
.button-error.data-v-50d9f1a2:active {
  background-color: #cf2d28;
}
.button-error.disabled.data-v-50d9f1a2 {
  background-color: #eda5a3 !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
