/* ---- 通用按钮样式 ---- */
.button-primary.data-v-47172ed4, .button-error.data-v-47172ed4 {
  font-size: 32rpx;
  padding: 18rpx 30rpx;
  border-radius: 1000px;
  text-align: center;
  line-height: 1.5;
  border: none;
  transition: background-color 0.2s ease, opacity 0.2s ease;
  display: flex;
  align-items: center;
