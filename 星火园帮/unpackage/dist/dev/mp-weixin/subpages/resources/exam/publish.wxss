}
.button-primary.data-v-47172ed4:active, .button-error.data-v-47172ed4:active {
  opacity: 0.8;
}
.disabled.button-primary.data-v-47172ed4, .disabled.button-error.data-v-47172ed4 {
  opacity: 0.6 !important;
  cursor: not-allowed;
  box-shadow: none;
}
.button-primary.data-v-47172ed4 {
  background-color: #007aff;
  color: #ffffff;
}
.button-primary.data-v-47172ed4:active {
  background-color: #0062cc;
}
.button-primary.disabled.data-v-47172ed4 {
  background-color: #66afff !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
.button-error.data-v-47172ed4 {
  background-color: #dd524d;
  color: #ffffff;
}
.button-error.data-v-47172ed4:active {
  background-color: #cf2d28;
}
.button-error.disabled.data-v-47172ed4 {
  background-color: #eda5a3 !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
