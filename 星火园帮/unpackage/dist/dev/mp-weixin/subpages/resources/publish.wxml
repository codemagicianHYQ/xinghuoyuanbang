<view class="publish-container data-v-6254d330"><form data-event-opts="{{[['submit',[['submitResource',['$event']]]]]}}" bindsubmit="__e" class="data-v-6254d330"><view class="form-section card data-v-6254d330"><view class="form-item data-v-6254d330"><text class="item-label data-v-6254d330">资源类型 <text class="required data-v-6254d330">*</text></text><picker class="picker data-v-6254d330" range="{{resourceTypes}}" range-key="name" data-event-opts="{{[['change',[['onTypeChange',['$event']]]]]}}" bindchange="__e"><view class="picker-value data-v-6254d330">{{''+(formData.type?$root.m0:"请选择资源类型")+''}}</view></picker></view><view class="form-item data-v-6254d330"><text class="item-label data-v-6254d330">标题 <text class="required data-v-6254d330">*</text></text><input class="input-field data-v-6254d330" placeholder="请输入资源标题" maxlength="50" data-event-opts="{{[['input',[['__set_model',['$0','title','$event',[]],['formData']]]]]}}" value="{{formData.title}}" bindinput="__e"/></view><view class="form-item data-v-6254d330"><text class="item-label data-v-6254d330">价格 <text class="required data-v-6254d330">*</text></text><input class="input-field data-v-6254d330" type="digit" placeholder="请输入价格" data-event-opts="{{[['input',[['__set_model',['$0','price','$event',[]],['formData']]]]]}}" value="{{formData.price}}" bindinput="__e"/></view><view class="form-item data-v-6254d330"><text class="item-label data-v-6254d330">成色 <text class="required data-v-6254d330">*</text></text><picker class="picker data-v-6254d330" range="{{conditions}}" data-event-opts="{{[['change',[['onConditionChange',['$event']]]]]}}" bindchange="__e"><view class="picker-value data-v-6254d330">{{''+(formData.condition||"请选择成色")+''}}</view></picker></view></view><view class="form-section card data-v-6254d330"><text class="section-title data-v-6254d330">上传图片 <text class="required data-v-6254d330">*</text></text><text class="section-subtitle data-v-6254d330">最多上传9张图片</text><view class="uploader-container data-v-6254d330"><block wx:for="{{formData.images}}" wx:for-item="image" wx:for-index="index" wx:key="index"><view class="image-item data-v-6254d330"><image class="preview-image data-v-6254d330" src="{{image}}" mode="aspectFill" data-event-opts="{{[['tap',[['previewImage',[index]]]]]}}" bindtap="__e"></image><text data-event-opts="{{[['tap',[['deleteImage',[index]]]]]}}" class="delete-btn data-v-6254d330" bindtap="__e">×</text></view></block><block wx:if="{{$root.g0<9}}"><view data-event-opts="{{[['tap',[['chooseImage',['$event']]]]]}}" class="upload-btn data-v-6254d330" bindtap="__e"><text class="upload-icon data-v-6254d330">+</text><text class="upload-text data-v-6254d330">上传图片</text></view></block></view></view><view class="form-section card data-v-6254d330"><text class="section-title data-v-6254d330">详细描述 <text class="required data-v-6254d330">*</text></text><textarea class="textarea-field data-v-6254d330" placeholder="请详细描述资源的具体情况，如使用年限、新旧程度、是否有瑕疵等" maxlength="500" data-event-opts="{{[['input',[['__set_model',['$0','description','$event',[]],['formData']]]]]}}" value="{{formData.description}}" bindinput="__e"></textarea><text class="word-count data-v-6254d330">{{$root.g1+"/500"}}</text></view><view class="form-section card data-v-6254d330"><text class="section-title data-v-6254d330">联系方式 <text class="required data-v-6254d330">*</text></text><input class="input-field data-v-6254d330" placeholder="请输入您的联系方式（如：微信/QQ）" maxlength="50" data-event-opts="{{[['input',[['__set_model',['$0','contact','$event',[]],['formData']]]]]}}" value="{{formData.contact}}" bindinput="__e"/></view><view class="agreement-section data-v-6254d330"><checkbox-group data-event-opts="{{[['change',[['onAgreementChange',['$event']]]]]}}" bindchange="__e" class="data-v-6254d330"><label class="agreement-label data-v-6254d330"><checkbox style="transform:scale(0.8);" value="{{true}}" checked="{{isAgreed}}" color="#2979ff" class="data-v-6254d330"></checkbox><text class="data-v-6254d330">我已阅读并同意</text></label></checkbox-group><text data-event-opts="{{[['tap',[['viewAgreement',['$event']]]]]}}" class="link-text data-v-6254d330" bindtap="__e">《平台交易协议》</text></view><button class="submit-btn data-v-6254d330" form-type="submit" disabled="{{!isAgreed||isSubmitting}}" loading="{{isSubmitting}}"> 发布资源 </button></form></view>