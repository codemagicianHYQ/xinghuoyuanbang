<view class="refund-status-container data-v-6c147fa6"><view class="header data-v-6c147fa6"><text class="title data-v-6c147fa6">退款状态</text></view><view class="refund-info data-v-6c147fa6"><view class="info-item data-v-6c147fa6"><text class="label data-v-6c147fa6">退款单号：</text><text class="value data-v-6c147fa6">{{refundInfo.refundNo}}</text></view><view class="info-item data-v-6c147fa6"><text class="label data-v-6c147fa6">退款金额：</text><text class="value amount data-v-6c147fa6">{{"¥"+refundInfo.amount}}</text></view><view class="info-item data-v-6c147fa6"><text class="label data-v-6c147fa6">申请时间：</text><text class="value data-v-6c147fa6">{{$root.m0}}</text></view><view class="info-item data-v-6c147fa6"><text class="label data-v-6c147fa6">退款原因：</text><text class="value data-v-6c147fa6">{{refundInfo.reason}}</text></view></view><view class="status-timeline data-v-6c147fa6"><view class="{{['timeline-item','data-v-6c147fa6',(true)?'active':'']}}"><view class="timeline-dot data-v-6c147fa6"></view><view class="timeline-content data-v-6c147fa6"><text class="timeline-title data-v-6c147fa6">退款申请已提交</text><text class="timeline-time data-v-6c147fa6">{{$root.m1}}</text></view></view><view class="{{['timeline-item','data-v-6c147fa6',(refundInfo.status!=='processing')?'active':'']}}"><view class="timeline-dot data-v-6c147fa6"></view><view class="timeline-content data-v-6c147fa6"><text class="timeline-title data-v-6c147fa6">退款处理中</text><block wx:if="{{refundInfo.status!=='processing'}}"><text class="timeline-time data-v-6c147fa6">{{''+$root.m2+''}}</text></block></view></view><view class="{{['timeline-item','data-v-6c147fa6',(refundInfo.status==='success')?'active':'']}}"><view class="timeline-dot data-v-6c147fa6"></view><view class="timeline-content data-v-6c147fa6"><text class="timeline-title data-v-6c147fa6">退款成功</text><block wx:if="{{refundInfo.status==='success'}}"><text class="timeline-time data-v-6c147fa6">{{''+$root.m3+''}}</text></block></view></view></view><block wx:if="{{refundInfo.status==='success'}}"><view class="status-message data-v-6c147fa6"><view class="success-icon data-v-6c147fa6">✓</view><text class="message data-v-6c147fa6">退款已成功，预计1-3个工作日到账</text></view></block><block wx:else><block wx:if="{{refundInfo.status==='failed'}}"><view class="status-message data-v-6c147fa6"><view class="error-icon data-v-6c147fa6">✗</view><text class="message data-v-6c147fa6">{{"退款失败："+refundInfo.errorMsg}}</text></view></block><block wx:else><view class="status-message data-v-6c147fa6"><view class="processing-icon data-v-6c147fa6">⏳</view><text class="message data-v-6c147fa6">退款处理中，请耐心等待</text></view></block></block><view class="action-buttons data-v-6c147fa6"><button class="refresh-btn data-v-6c147fa6" loading="{{isRefreshing}}" data-event-opts="{{[['tap',[['refreshStatus',['$event']]]]]}}" bindtap="__e"> 刷新状态 </button><button data-event-opts="{{[['tap',[['contactService',['$event']]]]]}}" class="contact-btn data-v-6c147fa6" bindtap="__e">联系客服</button></view></view>