}
.rounded-lg.data-v-6c147fa6 {
  border-radius: 16rpx !important;
}
.rounded-circle.data-v-6c147fa6 {
  border-radius: 50% !important;
}
.rounded-pill.data-v-6c147fa6 {
  border-radius: 1000px !important;
}
.shadow-sm.data-v-6c147fa6 {
