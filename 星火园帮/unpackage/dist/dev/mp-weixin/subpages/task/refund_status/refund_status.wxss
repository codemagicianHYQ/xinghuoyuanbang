/* ---- 通用辅助类 ---- */
.card.data-v-6c147fa6 {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0px 2px 8px rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}
.rounded-sm.data-v-6c147fa6 {
  border-radius: 4rpx !important;
}
.rounded-base.data-v-6c147fa6 {
