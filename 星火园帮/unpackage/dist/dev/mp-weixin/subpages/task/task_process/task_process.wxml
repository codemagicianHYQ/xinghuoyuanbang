<view class="order-process-container data-v-ebf512dc"><view class="status-section data-v-ebf512dc"><view class="{{['status-card','data-v-ebf512dc',statusCardClass]}}"><view class="status-icon data-v-ebf512dc"><uni-icons vue-id="92ac4698-1" type="{{statusIconType}}" size="48" color="{{statusIconColor}}" class="data-v-ebf512dc" bind:__l="__l"></uni-icons></view><text class="status-title data-v-ebf512dc">{{statusTitle}}</text><text class="status-desc data-v-ebf512dc">{{statusDescription}}</text></view></view><block wx:if="{{task}}"><view class="task-detail-container data-v-ebf512dc"><view class="task-basic-info data-v-ebf512dc"><view class="task-title-section data-v-ebf512dc"><text class="task-title data-v-ebf512dc">{{task.title||"无标题"}}</text><text class="task-reward data-v-ebf512dc">{{"¥"+getTaskAmount}}</text></view><view class="task-meta data-v-ebf512dc"><text class="{{['task-type','data-v-ebf512dc',taskTypeClass]}}">{{task.taskType}}</text><view class="{{['status-badge','data-v-ebf512dc',statusClass]}}">{{statusText}}</view></view><block wx:if="{{task.deadline&&task.deadline!=='null'}}"><text class="task-deadline data-v-ebf512dc">{{$root.m0+"截止"}}</text></block></view><view class="task-description-block data-v-ebf512dc"><view class="block-icon data-v-ebf512dc">📝</view><view class="block-content data-v-ebf512dc"><text class="block-title data-v-ebf512dc">任务描述</text><text class="block-text data-v-ebf512dc">{{taskDescription}}</text></view></view><block wx:if="{{task.specifics}}"><view class="task-details-block data-v-ebf512dc"><view class="block-icon data-v-ebf512dc">📋</view><view class="block-content data-v-ebf512dc"><text class="block-title data-v-ebf512dc">任务详情</text><text class="block-text data-v-ebf512dc">{{task.specifics}}</text></view></view></block><block wx:if="{{task.locationText}}"><view class="task-location-block data-v-ebf512dc"><view class="block-icon data-v-ebf512dc">📍</view><view class="block-content data-v-ebf512dc"><text class="block-title data-v-ebf512dc">任务地点</text><text class="block-text data-v-ebf512dc">{{$root.m1}}</text></view></view></block><view class="order-info-block data-v-ebf512dc"><view class="block-icon data-v-ebf512dc">📄</view><view class="block-content data-v-ebf512dc"><text class="block-title data-v-ebf512dc">订单信息</text><view class="order-info-list data-v-ebf512dc"><view class="order-info-item data-v-ebf512dc"><text class="order-label data-v-ebf512dc">单号</text><text class="order-value data-v-ebf512dc">{{orderNumber}}</text></view><view class="order-info-item data-v-ebf512dc"><text class="order-label data-v-ebf512dc">创建时间</text><text class="order-value data-v-ebf512dc">{{createTime}}</text></view><view class="order-info-item data-v-ebf512dc"><text class="order-label data-v-ebf512dc">接单时间</text><text class="order-value data-v-ebf512dc">{{acceptTime}}</text></view><block wx:if="{{task.publisherConfirmedTime}}"><view class="order-info-item data-v-ebf512dc"><text class="order-label data-v-ebf512dc">完成时间</text><text class="order-value data-v-ebf512dc">{{$root.m2}}</text></view></block></view></view></view><block wx:if="{{task&&(task.publisher||task.acceptor)}}"><view class="publisher-info-block data-v-ebf512dc"><view class="block-icon data-v-ebf512dc">😊</view><view class="block-content data-v-ebf512dc"><text class="block-title data-v-ebf512dc">{{isPublisher?"任务接单员":"任务发布者"}}</text><view class="publisher-details data-v-ebf512dc"><image class="publisher-avatar data-v-ebf512dc" src="{{isPublisher?$root.m3:$root.m4}}"></image><view class="publisher-detail data-v-ebf512dc"><text class="publisher-name data-v-ebf512dc">{{isPublisher?$root.m5:$root.m6}}</text></view></view></view><button data-event-opts="{{[['tap',[['contactPublisher',['$event']]]]]}}" class="contact-btn data-v-ebf512dc" bindtap="__e">{{''+(isPublisher?"联系接单员":"联系发布者")+''}}</button></view></block><block wx:if="{{!isPublisher&&task.status==='assigned'}}"><view class="confirm-images-card data-v-ebf512dc"><view class="confirm-images-title data-v-ebf512dc">订单确认凭证</view><view class="confirm-images-desc data-v-ebf512dc">请上传完成任务的图片凭证</view><view class="upload-area data-v-ebf512dc"><block wx:for="{{confirmImages}}" wx:for-item="image" wx:for-index="index" wx:key="index"><view class="confirm-image-item data-v-ebf512dc"><image class="confirm-uploaded-image data-v-ebf512dc" src="{{image}}" mode="aspectFill" data-event-opts="{{[['tap',[['previewImage',['$0'],[[['confirmImages','',index]]]]]]]}}" bindtap="__e"></image><view class="confirm-image-actions data-v-ebf512dc"><view data-event-opts="{{[['tap',[['previewImage',['$0'],[[['confirmImages','',index]]]]]]]}}" class="action-icon preview-icon data-v-ebf512dc" bindtap="__e"> 👁️ </view><view data-event-opts="{{[['tap',[['removeImage',[index]]]]]}}" class="action-icon delete-icon data-v-ebf512dc" bindtap="__e"> 🗑️ </view></view></view></block><block wx:if="{{$root.g0<maxImages}}"><view data-event-opts="{{[['tap',[['chooseImage',['$event']]]]]}}" class="upload-btn data-v-ebf512dc" bindtap="__e"><view class="upload-icon data-v-ebf512dc">📷</view><text class="upload-text data-v-ebf512dc">添加图片</text><text class="upload-tip data-v-ebf512dc">{{"最多"+maxImages+"张"}}</text></view></block></view></view></block><block wx:if="{{!isPublisher&&task&&task.status==='assigned'}}"><view class="fixed-bottom-actions data-v-ebf512dc"><button data-event-opts="{{[['tap',[['handleRejectClick',['$event']]]]]}}" class="{{['reject-btn','data-v-ebf512dc',(!canRejectTask)?'disabled':'']}}" bindtap="__e">{{''+rejectButtonText+''}}</button><button class="complete-btn data-v-ebf512dc" loading="{{isLoading}}" disabled="{{isLoading}}" data-event-opts="{{[['tap',[['markAsComplete',['$event']]]]]}}" bindtap="__e"> 标记完成 </button></view></block><block wx:if="{{isPublisher&&task&&task.status==='acceptor_done'}}"><button class="confirm-btn fixed-bottom-btn data-v-ebf512dc" loading="{{isConfirming}}" disabled="{{isConfirming}}" data-event-opts="{{[['tap',[['confirmTaskComplete',['$event']]]]]}}" bindtap="__e"> 确认完成 </button></block></view></block><block wx:if="{{!task&&isLoading}}"><view class="loading-container data-v-ebf512dc"><uni-load-more vue-id="92ac4698-2" status="loading" content-text="{ contentText: { contentdown: '加载中...' } }" class="data-v-ebf512dc" bind:__l="__l"></uni-load-more></view></block></view>