/* ---- 通用按钮样式 ---- */
.button-error.data-v-e1eb6848, .button-primary.data-v-e1eb6848 {
  font-size: 32rpx;
  padding: 18rpx 30rpx;
  border-radius: 1000px;
  text-align: center;
  line-height: 1.5;
  border: none;
  transition: background-color 0.2s ease, opacity 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}
.button-error.data-v-e1eb6848:active, .button-primary.data-v-e1eb6848:active {
  opacity: 0.8;
}
.disabled.button-error.data-v-e1eb6848, .disabled.button-primary.data-v-e1eb6848 {
  opacity: 0.6 !important;
  cursor: not-allowed;
  box-shadow: none;
}
.button-primary.data-v-e1eb6848 {
  background-color: #007aff;
  color: #ffffff;
}
.button-primary.data-v-e1eb6848:active {
  background-color: #0062cc;
}
.button-primary.disabled.data-v-e1eb6848 {
  background-color: #66afff !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
.button-error.data-v-e1eb6848 {
