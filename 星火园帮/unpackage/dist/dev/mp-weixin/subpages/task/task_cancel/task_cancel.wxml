<view class="order-cancel-container data-v-e1eb6848"><view class="header data-v-e1eb6848"><text class="title data-v-e1eb6848">取消订单</text></view><view class="order-info data-v-e1eb6848"><view class="order-item data-v-e1eb6848"><text class="label data-v-e1eb6848">订单号：</text><text class="value data-v-e1eb6848">{{orderInfo.orderNo}}</text></view><view class="order-item data-v-e1eb6848"><text class="label data-v-e1eb6848">任务标题：</text><text class="value data-v-e1eb6848">{{orderInfo.taskTitle}}</text></view><view class="order-item data-v-e1eb6848"><text class="label data-v-e1eb6848">订单金额：</text><text class="value amount data-v-e1eb6848">{{"¥"+$root.m0}}</text></view><view class="order-item data-v-e1eb6848"><text class="label data-v-e1eb6848">支付时间：</text><text class="value data-v-e1eb6848">{{$root.m1}}</text></view></view><view class="cancel-form data-v-e1eb6848"><view class="form-item data-v-e1eb6848"><text class="label data-v-e1eb6848">取消原因 <text class="required data-v-e1eb6848">*</text></text><picker range="{{cancelReasons}}" data-event-opts="{{[['change',[['onReasonChange',['$event']]]]]}}" bindchange="__e" class="data-v-e1eb6848"><view class="picker-value data-v-e1eb6848">{{''+(selectedReason||"请选择取消原因")+''}}<text class="arrow data-v-e1eb6848">></text></view></picker></view><block wx:if="{{selectedReason==='其他'}}"><view class="form-item data-v-e1eb6848"><text class="label data-v-e1eb6848">详细说明</text><textarea class="textarea data-v-e1eb6848" placeholder="请详细说明取消原因" maxlength="200" data-event-opts="{{[['input',[['__set_model',['','customReason','$event',[]]]]]]}}" value="{{customReason}}" bindinput="__e"></textarea></view></block><view class="refund-info data-v-e1eb6848"><text class="refund-title data-v-e1eb6848">退款信息</text><view class="refund-item data-v-e1eb6848"><text class="label data-v-e1eb6848">退款金额：</text><text class="value data-v-e1eb6848">{{"¥"+$root.m2}}</text></view><view class="refund-item data-v-e1eb6848"><text class="label data-v-e1eb6848">退款方式：</text><text class="value data-v-e1eb6848">微信零钱</text></view><view class="refund-item data-v-e1eb6848"><text class="label data-v-e1eb6848">预计到账：</text><text class="value data-v-e1eb6848">立刻到账</text></view></view></view><view class="action-buttons data-v-e1eb6848"><button class="cancel-btn data-v-e1eb6848" disabled="{{isSubmitting}}" data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" bindtap="__e"> 返回 </button><button class="confirm-btn data-v-e1eb6848" loading="{{isSubmitting}}" disabled="{{isSubmitting}}" data-event-opts="{{[['tap',[['confirmCancel',['$event']]]]]}}" bindtap="__e"> 确认取消 </button></view></view>