/* ---- 通用辅助类 ---- */
.card.data-v-5ec3677d {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0px 2px 8px rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}
.rounded-sm.data-v-5ec3677d {
  border-radius: 4rpx !important;
}
.rounded-base.data-v-5ec3677d {
  border-radius: 8rpx !important;
}
.rounded-lg.data-v-5ec3677d {
  border-radius: 16rpx !important;
}
.rounded-circle.data-v-5ec3677d {
  border-radius: 50% !important;
}
.rounded-pill.data-v-5ec3677d {
  border-radius: 1000px !important;
}
.shadow-sm.data-v-5ec3677d {
  box-shadow: 0px 1px 4px rgba(0, 0, 0, 0.06) !important;
}
.shadow-base.data-v-5ec3677d {
  box-shadow: 0px 2px 8px rgba(0, 0, 0, 0.08) !important;
}
.shadow-lg.data-v-5ec3677d {
  box-shadow: 0px 4px 16px rgba(0, 0, 0, 0.12) !important;
}
/* 页面容器基础样式 */
.page-container.data-v-5ec3677d {
  min-height: 100vh;
  background-color: #f8f8f8;
  box-sizing: border-box;
  padding: 16rpx;
}
/* ---- 通用按钮样式 ---- */
.button-error.data-v-5ec3677d, .button-primary.data-v-5ec3677d {
  font-size: 32rpx;
  padding: 18rpx 30rpx;
  border-radius: 1000px;
  text-align: center;
  line-height: 1.5;
  border: none;
  transition: background-color 0.2s ease, opacity 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}
.button-error.data-v-5ec3677d:active, .button-primary.data-v-5ec3677d:active {
  opacity: 0.8;
}
.disabled.button-error.data-v-5ec3677d, .disabled.button-primary.data-v-5ec3677d {
  opacity: 0.6 !important;
  cursor: not-allowed;
  box-shadow: none;
}
.button-primary.data-v-5ec3677d {
  background-color: #007aff;
  color: #ffffff;
}
.button-primary.data-v-5ec3677d:active {
  background-color: #0062cc;
}
.button-primary.disabled.data-v-5ec3677d {
  background-color: #66afff !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
.button-error.data-v-5ec3677d {
  background-color: #dd524d;
  color: #ffffff;
}
.button-error.data-v-5ec3677d:active {
  background-color: #cf2d28;
}
.button-error.disabled.data-v-5ec3677d {
  background-color: #eda5a3 !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
/* ---- 你可以在下方继续添加项目中其他自定义的全局 SASS 变量或通用样式 ---- */
.fun-title.data-v-5ec3677d {
  font-family: "ZCOOL KuaiLe", "Smiley Sans", "PingFang SC", "Microsoft YaHei", Arial, sans-serif !important;
  font-weight: bold;
  font-size: 36rpx;
  color: #222;
  letter-spacing: 2rpx;
  line-height: 1.2;
}
.fun-announcement.data-v-5ec3677d {
  font-family: "ZCOOL KuaiLe", "Smiley Sans", "PingFang SC", "Microsoft YaHei", Arial, sans-serif !important;
  font-size: 28rpx;
  color: #222;
  font-weight: bold;
  letter-spacing: 1.5rpx;
}
.fun-tab-label.data-v-5ec3677d {
  font-family: "ZCOOL KuaiLe", "Smiley Sans", "PingFang SC", "Microsoft YaHei", Arial, sans-serif !important;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.purchased-container.data-v-5ec3677d {
  min-height: 100vh;
  background: linear-gradient(135deg, #e3f2fd 0%, #f0f8ff 50%, #e8f4fd 100%);
  padding-bottom: 120rpx;
}
/* 商品网格 */
.products-grid.data-v-5ec3677d {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 32rpx;
}
/* 商品卡片 */
.product-card.data-v-5ec3677d {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: -webkit-transform 0.3s ease;
  transition: transform 0.3s ease;
  transition: transform 0.3s ease, -webkit-transform 0.3s ease;
}
.product-card.data-v-5ec3677d:active {
  -webkit-transform: scale(0.98);
          transform: scale(0.98);
}
/* 商品图片 */
.product-image-container.data-v-5ec3677d {
  position: relative;
  width: 100%;
  height: 200rpx;
  overflow: hidden;
}
.product-image.data-v-5ec3677d {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.purchased-tag.data-v-5ec3677d {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: linear-gradient(135deg, #4ecdc4 0%, #44a08d 100%);
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}
/* 商品信息 */
.product-info.data-v-5ec3677d {
  padding: 20rpx;
}
.product-title.data-v-5ec3677d {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
}
.product-price.data-v-5ec3677d {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.current-price.data-v-5ec3677d {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff4757;
}
.original-price.data-v-5ec3677d {
  font-size: 24rpx;
  color: #999999;
  text-decoration: line-through;
}
.product-meta.data-v-5ec3677d {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: 12rpx;
}
.seller.data-v-5ec3677d,
.purchase-date.data-v-5ec3677d {
  font-size: 22rpx;
  color: #666666;
}
.product-tags.data-v-5ec3677d {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}
.tag.data-v-5ec3677d {
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
  background-color: #f0f0f0;
  color: #666666;
}
.tag.condition.data-v-5ec3677d {
  background-color: #e8f5e8;
  color: #4caf50;
}
/* 空状态 */
.empty-state.data-v-5ec3677d {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  text-align: center;
}
.empty-icon.data-v-5ec3677d {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}
.empty-title.data-v-5ec3677d {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}
.empty-desc.data-v-5ec3677d {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 48rpx;
}
.go-shopping-btn.data-v-5ec3677d {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border: none;
  border-radius: 24rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.go-shopping-btn.data-v-5ec3677d:active {
  opacity: 0.8;
}
