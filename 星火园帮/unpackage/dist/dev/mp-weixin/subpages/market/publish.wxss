}
.button-primary.disabled.data-v-453c1389 {
  background-color: #66afff !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
.button-error.data-v-453c1389 {
  background-color: #dd524d;
  color: #ffffff;
}
.button-error.data-v-453c1389:active {
  background-color: #cf2d28;
}
.button-error.disabled.data-v-453c1389 {
  background-color: #eda5a3 !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
