Data.realName}}" bindinput="__e"/></view><view class="form-item data-v-4633bf10"><uni-icons class="input-icon data-v-4633bf10" vue-id="804320e4-5" type="phone" size="20" color="#A0A0A0" bind:__l="__l"></uni-icons><input class="input-field data-v-4633bf10" type="number" name="phoneNumber" placeholder="请输入手机号码" maxlength="11" data-event-opts="{{[['input',[['__set_model',['$0','phoneNumber','$event',[]],['formData']]]]]}}" value="{{formData.phoneNumber}}" bindinput="__e"/></view></view><button class="submit-btn data-v-4633bf10" form-type="submit" loading="{{isSubmitting}}" disabled="{{!isAgreed||isSubmitting}}" data-event-opts="{{[['tap',[['submitApplication',['$event']]]]]}}" bindtap="__e"> 提交审核 </button><view class="agreement-section data-v-4633bf10"><checkbox-group data-event-opts="{{[['change',[['onAgreementChange',['$event']]]]]}}" bindchange="__e" class="data-v-4633bf10"><label class="agreement-label data-v-4633bf10"><checkbox style="transform:scale(0.8);" value="{{true}}" checked="{{isAgreed}}" color="#2979ff" class="data-v-4633bf10"></checkbox><text class="data-v-4633bf10">我已同意并阅读</text></label></checkbox-group><text data-event-opts="{{[['tap',[['viewRiderAgreement',['$event']]]]]}}" class="link-text data-v-4633bf10" bindtap="__e">《申请接单员协议》</text></view></view></block></view>