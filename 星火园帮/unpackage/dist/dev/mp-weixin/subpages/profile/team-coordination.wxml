<view class="team-coordination-container"><view class="header-section"><view class="header-title">团队协调</view><view class="header-subtitle">管理您的接单任务</view></view><view class="section"><view class="section-title">进行中的订单</view><block wx:if="{{loading}}"><view class="loading-placeholder"><text>加载中...</text></view></block><block wx:else><block wx:if="{{$root.g0===0}}"><view class="empty-placeholder"><view class="empty-icon">暂无</view><text class="empty-text">暂无进行中的订单</text></view></block><block wx:else><view class="order-list"><block wx:for="{{$root.l0}}" wx:for-item="order" wx:for-index="__i0__" wx:key="id"><view class="order-item"><view class="order-info"><text class="order-title">{{order.$orig.title}}</text><text class="order-type">{{order.m0}}</text><text class="order-amount">{{"¥"+order.$orig.rewardAmount}}</text><text class="order-time">{{"创建: "+order.m1}}</text><block wx:if="{{order.$orig.acceptedAt}}"><text class="order-time">{{"接单: "+order.m2}}</text></block><block wx:if="{{order.$orig.publisherConfirmedTime}}"><text class="order-time">{{"完成: "+order.m3}}</text></block></view><view class="order-actions"><button class="action-btn transfer-btn" disabled="{{!order.m4}}" data-event-opts="{{[['tap',[['showTransferModal',['$0'],[[['activeOrders','id',order.$orig.id]]]]]]]}}" bindtap="__e"> 转单 </button><button class="action-btn reject-btn" disabled="{{!order.m5}}" data-event-opts="{{[['tap',[['showRejectModal',['$0'],[[['activeOrders','id',order.$orig.id]]]]]]]}}" bindtap="__e"> 驳回 </button></view></view></block></view></block></block></view><block wx:if="{{showTransfer}}"><view data-event-opts="{{[['tap',[['closeTransferModal',['$event']]]]]}}" class="modal-overlay" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="modal-content" catchtap="__e"><view class="modal-header"><text class="modal-title">转单给团队成员</text><text data-event-opts="{{[['tap',[['closeTransferModal',['$event']]]]]}}" class="modal-close" bindtap="__e">关闭</text></view><view class="modal-body"><text class="modal-subtitle">选择要转单的团队成员</text><view class="team-members"><block wx:for="{{availableMembers}}" wx:for-item="member" wx:for-index="__i1__" wx:key="id"><view data-event-opts="{{[['tap',[['selectMember',['$0'],[[['availableMembers','id',member.id]]]]]]]}}" class="{{['member-item',(selectedMember&&selectedMember.id===member.id)?'selected':'']}}" bindtap="__e"><image class="member-avatar" src="{{member.avatarUrl||'/static/images/default-avatar.png'}}" mode="aspectFill"></image><view class="member-info"><text class="member-name">{{member.nickname}}</text><text class="member-status">在线</text></view></view></block></view><block wx:if="{{$root.g1===0}}"><view class="no-members"><text>暂无可转单的团队成员</text></view></block></view><view class="modal-footer"><button data-event-opts="{{[['tap',[['closeTransferModal',['$event']]]]]}}" class="modal-btn cancel-btn" bindtap="__e"> 取消 </button><button class="modal-btn confirm-btn" disabled="{{!selectedMember}}" data-event-opts="{{[['tap',[['confirmTransfer',['$event']]]]]}}" bindtap="__e"> 确认转单 </button></view></view></view></block><block wx:if="{{showReject}}"><view data-event-opts="{{[['tap',[['closeRejectModal',['$event']]]]]}}" class="modal-overlay" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="modal-content" catchtap="__e"><view class="modal-header"><text class="modal-title">驳回订单</text><text data-event-opts="{{[['tap',[['closeRejectModal',['$event']]]]]}}" class="modal-close" bindtap="__e">关闭</text></view><view class="modal-body"><text class="modal-subtitle">确认要驳回此订单吗？</text><view class="order-detail"><text class="order-title">{{selectedOrder&&selectedOrder.title}}</text><text class="order-type">{{$root.m6}}</text><text class="order-amount">{{"¥"+(selectedOrder&&selectedOrder.rewardAmount)}}</text></view><text class="warning-text">驳回后订单将返回订单大厅，系统会通知发布者</text><text class="time-limit-text">注意：驳回功能仅在接单后10分钟内有效</text></view><view class="modal-footer"><button data-event-opts="{{[['tap',[['closeRejectModal',['$event']]]]]}}" class="modal-btn cancel-btn" bindtap="__e"> 取消 </button><button data-event-opts="{{[['tap',[['confirmReject',['$event']]]]]}}" class="modal-btn reject-confirm-btn" bindtap="__e"> 确认驳回 </button></view></view></view></block></view>