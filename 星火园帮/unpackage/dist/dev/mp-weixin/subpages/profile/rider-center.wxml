']]]]]}}" class="modal-btn cancel-btn data-v-6810023b" bindtap="__e"> 取消 </button><button class="modal-btn confirm-btn data-v-6810023b" disabled="{{!$root.g2}}" data-event-opts="{{[['tap',[['submitTeamApplication',['$event']]]]]}}" bindtap="__e"> 提交申请 </button></view></view></view></block></view>