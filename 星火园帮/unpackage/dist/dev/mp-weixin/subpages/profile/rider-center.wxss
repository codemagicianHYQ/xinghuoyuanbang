/* ---- 通用按钮样式 ---- */
.button-error.data-v-6810023b, .button-primary.data-v-6810023b {
  font-size: 32rpx;
  padding: 18rpx 30rpx;
  border-radius: 1000px;
  text-align: center;
  line-height: 1.5;
  border: none;
  transition: background-color 0.2s ease, opacity 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}
.button-error.data-v-6810023b:active, .button-primary.data-v-6810023b:active {
  opacity: 0.8;
}
.disabled.button-error.data-v-6810023b, .disabled.button-primary.data-v-6810023b {
  opacity: 0.6 !important;
  cursor: not-allowed;
  box-shadow: none;
}
.button-primary.data-v-6810023b {
  background-color: #007aff;
  color: #ffffff;
}
.button-primary.data-v-6810023b:active {
  background-color: #0062cc;
}
.button-primary.disabled.data-v-6810023b {
  background-color: #66afff !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
.button-error.data-v-6810023b {
  background-color: #dd524d;
  color: #ffffff;
}
.button-error.data-v-6810023b:active {
  background-color: #cf2d28;
}
.button-error.disabled.data-v-6810023b {
  background-color: #eda5a3 !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
