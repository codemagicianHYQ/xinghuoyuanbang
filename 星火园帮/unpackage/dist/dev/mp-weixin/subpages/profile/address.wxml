<view class="address-container page-container data-v-9f07e1de"><view class="fun-title data-v-9f07e1de" style="margin-bottom:32rpx;">我的地址</view><block wx:if="{{$root.g0===0}}"><view class="empty-tip data-v-9f07e1de">暂无地址，请点击下方按钮添加</view></block><block wx:for="{{addressList}}" wx:for-item="item" wx:for-index="idx" wx:key="id"><view class="address-card card data-v-9f07e1de"><view class="address-info data-v-9f07e1de"><text class="address-detail data-v-9f07e1de">{{item.detail}}</text><block wx:if="{{item.isDefault}}"><text class="address-tag data-v-9f07e1de">默认</text></block><view class="data-v-9f07e1de">{{item.name+" "+item.phone}}</view></view><view class="address-actions data-v-9f07e1de"><button data-event-opts="{{[['tap',[['editAddress',[idx]]]]]}}" class="edit-btn data-v-9f07e1de" bindtap="__e">编辑</button><button data-event-opts="{{[['tap',[['confirmDelete',[idx]]]]]}}" class="delete-btn data-v-9f07e1de" bindtap="__e">删除</button></view></view></block><button data-event-opts="{{[['tap',[['addAddress',['$event']]]]]}}" class="add-btn button-primary rounded-pill data-v-9f07e1de" bindtap="__e"> 添加新地址 </button><block wx:if="{{deleteIndex!==-1}}"><uni-popup vue-id="5f065415-1" type="dialog" data-ref="deletePopup" class="data-v-9f07e1de vue-ref" bind:__l="__l" vue-slots="{{['default']}}"><view class="popup-content data-v-9f07e1de"><view class="fun-title data-v-9f07e1de" style="font-size:30rpx;">确认删除该地址？</view><view class="popup-actions data-v-9f07e1de"><button data-event-opts="{{[['tap',[['doDeleteAddress',['$event']]]]]}}" class="button-error data-v-9f07e1de" bindtap="__e">确认</button><button data-event-opts="{{[['tap',[['closeDeletePopup',['$event']]]]]}}" class="button-primary data-v-9f07e1de" bindtap="__e">取消</button></view></view></uni-popup></block></view>