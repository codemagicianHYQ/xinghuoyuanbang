<view class="ask-publish-container page-container data-v-b3a6d2da"><view class="header-decoration data-v-b3a6d2da"><view class="title-section data-v-b3a6d2da"><text class="page-title data-v-b3a6d2da">发布问答</text><text class="page-subtitle data-v-b3a6d2da">有问题？来这里寻找答案吧！</text></view></view><form data-event-opts="{{[['submit',[['submitAskRequest',['$event']]]]]}}" bindsubmit="__e" class="data-v-b3a6d2da"><view class="form-section card rounded-lg shadow-base data-v-b3a6d2da"><view class="form-item data-v-b3a6d2da"><view class="label-with-icon data-v-b3a6d2da"><text class="item-icon data-v-b3a6d2da">📝</text><text class="item-label data-v-b3a6d2da">问题标题 <text class="required-star data-v-b3a6d2da">*</text></text></view><input class="input-field rounded-base data-v-b3a6d2da" name="title" placeholder="请输入您的问题标题" maxlength="50" data-event-opts="{{[['input',[['__set_model',['$0','title','$event',[]],['formData']]]]]}}" value="{{formData.title}}" bindinput="__e"/></view><view class="form-item data-v-b3a6d2da"><view class="label-with-icon data-v-b3a6d2da"><text class="item-icon data-v-b3a6d2da">🏷️</text><text class="item-label data-v-b3a6d2da">问题类型</text></view><picker range="{{questionTypes}}" range-key="name" data-event-opts="{{[['change',[['onTypeChange',['$event']]]]]}}" bindchange="__e" class="data-v-b3a6d2da"><view class="picker-value input-imitation rounded-base data-v-b3a6d2da">{{''+(formData.type?$root.m0:"请选择问题类型")+''}}<text class="uni-icon uni-icon-arrowdown picker-arrow data-v-b3a6d2da"></text></view></picker></view><view class="form-item data-v-b3a6d2da"><view class="label-with-icon data-v-b3a6d2da"><text class="item-icon data-v-b3a6d2da">📋</text><text class="item-label data-v-b3a6d2da">问题描述 <text class="required-star data-v-b3a6d2da">*</text></text></view><textarea class="textarea-field rounded-base textarea-enhanced data-v-b3a6d2da" name="description" placeholder="请详细描述您的问题，包括背景、具体困难等..." maxlength="500" data-event-opts="{{[['input',[['__set_model',['$0','description','$event',[]],['formData']]]]]}}" value="{{formData.description}}" bindinput="__e"></textarea><view class="char-count data-v-b3a6d2da">{{$root.g0+"/500"}}</view></view><view class="form-item data-v-b3a6d2da"><view class="label-with-icon data-v-b3a6d2da"><text class="item-icon data-v-b3a6d2da">📞</text><text class="item-label data-v-b3a6d2da">联系方式</text></view><input class="input-field rounded-base contact-input data-v-b3a6d2da" name="contact" placeholder="微信号、QQ号等，方便回答者联系" maxlength="50" data-event-opts="{{[['input',[['__set_model',['$0','contact','$event',[]],['formData']]]]]}}" value="{{formData.contact}}" bindinput="__e"/></view><view class="form-item data-v-b3a6d2da"><view class="label-with-icon data-v-b3a6d2da"><text class="item-icon data-v-b3a6d2da">⏰</text><text class="item-label data-v-b3a6d2da">截止时间</text></view><picker mode="date" value="{{formData.deadline}}" data-event-opts="{{[['change',[['onDeadlineChange',['$event']]]]]}}" bindchange="__e" class="data-v-b3a6d2da"><view class="picker-value input-imitation rounded-base data-v-b3a6d2da">{{''+(formData.deadline||"请选择截止时间")+''}}<text class="uni-icon uni-icon-arrowdown picker-arrow data-v-b3a6d2da"></text></view></picker></view></view><view class="submit-section data-v-b3a6d2da"><button class="submit-btn ask-btn rounded-full data-v-b3a6d2da" disabled="{{!isFormValid||isSubmitting}}" loading="{{isSubmitting}}" data-event-opts="{{[['tap',[['submitAskRequest',['$event']]]]]}}" bindtap="__e"><text class="btn-icon data-v-b3a6d2da">🚀</text><text class="btn-text data-v-b3a6d2da">{{isSubmitting?"发布中...":"发布问答"}}</text></button></view></form></view>