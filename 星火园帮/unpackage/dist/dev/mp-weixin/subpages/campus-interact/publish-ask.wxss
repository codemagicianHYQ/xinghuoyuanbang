  min-height: 100vh;
  background-color: #f8f8f8;
  box-sizing: border-box;
  padding: 16rpx;
}
/* ---- 通用按钮样式 ---- */
.button-primary.data-v-b3a6d2da, .button-error.data-v-b3a6d2da {
  font-size: 32rpx;
  padding: 18rpx 30rpx;
  border-radius: 1000px;
  text-align: center;
  line-height: 1.5;
  border: none;
  transition: background-color 0.2s ease, opacity 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}
.button-primary.data-v-b3a6d2da:active, .button-error.data-v-b3a6d2da:active {
  opacity: 0.8;
}
.disabled.button-primary.data-v-b3a6d2da, .disabled.button-error.data-v-b3a6d2da {
  opacity: 0.6 !important;
  cursor: not-allowed;
  box-shadow: none;
}
.button-primary.data-v-b3a6d2da {
  background-color: #007aff;
  color: #ffffff;
}
.button-primary.data-v-b3a6d2da:active {
  background-color: #0062cc;
}
.button-primary.disabled.data-v-b3a6d2da {
  background-color: #66afff !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
.button-error.data-v-b3a6d2da {
  background-color: #dd524d;
  color: #ffffff;
}
.button-error.data-v-b3a6d2da:active {
  background-color: #cf2d28;
}
.button-error.disabled.data-v-b3a6d2da {
  background-color: #eda5a3 !important;
  color: rgba(255, 255, 255, 0.7) !important;
}
