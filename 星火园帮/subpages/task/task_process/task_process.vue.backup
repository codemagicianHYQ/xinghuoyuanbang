    // 请求通知授权
    requestNotificationAuth() {
      return new Promise(async (resolve) => {
        // 先检查是否已经授权过
        const hasAuthorized = uni.getStorageSync("hasAuthorizedSubscription");
        if (hasAuthorized === true) {
"用户已经授权过订阅消息，跳过授权弹窗");
          resolve(true);
          return;
        }

        uni.showModal({
          title: "开启消息通知",
          content: "为了及时接收订单相关通知，请授权接收订阅消息",
          confirmText: "去授权",
          cancelText: "稍后再说",
          success: (res) => {
            if (res.confirm) {
              wx.requestSubscribeMessage({
                tmplIds: [
                  "vtPkIE3rnciTE0kVXE3WVhmz6KUkATBh5Nl9LytMX0g", // 新任务通知
                  "58VecsBQtioKWF8uBfXjhtSyX2MmzNcXqaZUQJk_oe4", // 接单通知
                  "Buc3PRwms6j6QV5dPjzJwo0QmCGts5OU9x8TTxyhxc4", // 送达通知
                  "e4Jkk2iypweLiPMBqQbWgbx189wjq3hZGG6An-_sS5A", // 完成通知
                ],
                success: (authRes) => {
"订阅消息授权结果:", authRes);
                    "授权结果详情:",
                    JSON.stringify(authRes, null, 2)
                  );

                  const acceptedCount = Object.values(authRes).filter(
                    (status) => status === "accept"
                  ).length;

`用户授权了 ${acceptedCount} 个模板`);

                  if (acceptedCount > 0) {
                    // 保存授权状态
                    uni.setStorageSync("hasAuthorizedSubscription", true);
                    uni.setStorageSync("orderNotificationSetting", true);
                    uni.showToast({
                      title: `已授权${acceptedCount}个通知`,
                      icon: "success",
                    });
                  } else {
                    uni.setStorageSync("hasAuthorizedSubscription", false);
                    uni.showToast({
                      title: "可稍后在设置中开启通知",
                      icon: "none",
                      duration: 3000,
                    });
                  }
                  resolve(true);
                },
                fail: (err) => {
"订阅消息授权失败:", err);
                  resolve(false);
                },
              });
            } else {
              resolve(false);
            }
          },
        });
      });
    },

    getPublisherAvatar() {
      return (
        (this.task && this.task.publisher && this.task.publisher.avatarUrl) ||
        "/static/images/default-avatar.png"
      );
    },
    getPublisherName() {
      return (
        (this.task && this.task.publisher && this.task.publisher.nickname) ||
        "匿名用户"
      );
    },
    getAcceptorAvatar() {
      return (
        (this.task && this.task.acceptor && this.task.acceptor.avatarUrl) ||
        "/static/images/default-avatar.png"
      );
    },
    getAcceptorName() {
      return (
        (this.task && this.task.acceptor && this.task.acceptor.nickname) ||
        "匿名用户"
      );
    },

    cleanHtmlContent(html) {
      if (!html) return "";
      // 移除所有HTML标签
      return html.replace(/<[^>]*>/g, "");
    },

    // 联系发布者
    contactPublisher() {
      if (!this.task || !this.task.publisher) {
        uni.showToast({
          title: "发布者信息不存在",
          icon: "none",
        });
        return;
      }

      // 跳转到聊天页面
      uni.navigateTo({
        url: `/pages/chat/chat?taskId=${this.taskId}&userId=${
          this.task.publisher.id
        }&userName=${this.task.publisher.nickname || "发布者"}`,
      });
    },
    getGenderText(gender) {
      if (gender === 1) return "男生";
      if (gender === 2) return "女生";
      return "未知";
    },
    formatOrderNumber(outTradeNo) {
"[formatOrderNumber] 调用时的outTradeNo:", outTradeNo);
      if (!outTradeNo || outTradeNo === null || outTradeNo === "null")
        return "";
      // 去掉 ORDER 前缀，只保留数字部分
      const cleanOrderNo = outTradeNo.replace(/^ORDER\s*/, "");
      // 完整显示订单号
      return cleanOrderNo;
    },
    formatDateTime(dateTime) {
"[formatDateTime] 调用时的dateTime:", dateTime);
      if (!dateTime || dateTime === null || dateTime === "null") return "";
      try {
        const date = new Date(dateTime);
        if (isNaN(date.getTime())) return "";
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, "0");
        const day = String(date.getDate()).padStart(2, "0");
        const hour = String(date.getHours()).padStart(2, "0");
        const minute = String(date.getMinutes()).padStart(2, "0");
        return `${year}-${month}-${day} ${hour}:${minute}`;
      } catch (error) {
        return dateTime;
      }
    },
    // 获取任务地点显示文本
    getTaskLocation(task) {
      if (!task) return "未知地点";

        "[getTaskLocation] 调用时的task.locationText:",
        task.locationText
      );
"[getTaskLocation] 调用时的task.specifics:", task.specifics);

      const taskType = task.taskType || "";

      // 根据任务类型优化地点显示
      switch (taskType) {
        case "游戏开黑":
          return "线上游戏";

        case "搬运服务":
          // 解析具体信息，提取起始地点
          if (task.specifics) {
            const startLocationMatch = task.specifics.match(
              /起始地点[:：]\s*([^,，\n]+)/
            );
            if (startLocationMatch) {
              return startLocationMatch[1].trim();
            }
          }
          return task.locationText || "搬运地点";

        case "找搭子":
          // 解析具体信息，提取活动地点
          if (task.specifics) {
            const activityMatch = task.specifics.match(
              /活动地点[:：]\s*([^,，\n]+)/
            );
            if (activityMatch) {
              return activityMatch[1].trim();
            }
          }
          return task.locationText || "活动地点";

        case "分身服务":
          return "线上服务";

        case "分身服务":
          // 解析具体信息，提取上课地点
          if (task.specifics) {
            const classLocationMatch = task.specifics.match(
              /上课地点[:：]\s*([^,，\n]+)/
            );
            if (classLocationMatch) {
              return classLocationMatch[1].trim();
            }
          }
          // 如果是线上课程
          if (task.specifics && task.specifics.includes("线上")) {
            return "线上课程";
          }
          return task.locationText || "教学楼";

        case "取快递":
        case "取外卖":
          // 解析具体信息，提取送达地址
          if (task.specifics) {
            const deliveryMatch = task.specifics.match(
              /送达地址[:：]\s*([^,，\n]+)/
            );
            if (deliveryMatch) {
              return "送：" + deliveryMatch[1].trim();
            }
          }
          // 如果locationText为空或null，返回默认值
          if (
            task.locationText &&
            task.locationText !== "null" &&
            task.locationText.trim()
          ) {
            return "送：" + task.locationText;
          }
          return "杭州市滨江区"; // 默认地点

        case "帮我买":
          if (task.specifics) {
            const shopMatch = task.specifics.match(
              /购买地点[:：]\s*([^,，\n]+)/
            );
            if (shopMatch) {
              return shopMatch[1].trim();
            }
          }
          return task.locationText || "购买地点";

        case "借物品":
          // 解析具体信息，提取取货地点
          if (task.specifics) {
            const pickupMatch = task.specifics.match(
              /取货地点[:：]\s*([^,，\n]+)/
            );
            if (pickupMatch) {
              return pickupMatch[1].trim();
            }
          }
          return task.locationText || "取货地点";

        case "求资料":
          return "线上服务";

        case "其他帮助":
          return task.locationText || "待定地点";

        default:
          // 如果地点为空、null或只有空格，显示默认地点
          if (
            !task.locationText ||
            task.locationText === "null" ||
            task.locationText.trim() === "" ||
            task.locationText === "空"
          ) {
            return "杭州市滨江区";
          }
          return task.locationText;
      }
    },

    // 选择图片
    chooseImage() {
      if (this.confirmImages.length >= this.maxImages) {
        uni.showToast({
          title: `最多只能上传${this.maxImages}张图片`,
          icon: "none",
        });
        return;
      }

      uni.chooseImage({
        count: this.maxImages - this.confirmImages.length,
        sizeType: ["compressed"],
        sourceType: ["album", "camera"],
        success: (res) => {
          this.uploadImages(res.tempFilePaths);
        },
        fail: (error) => {
          // 检查是否是用户取消了选择
          if (error.errMsg === "chooseImage:fail cancel") {
"用户取消了图片选择");
            // 不显示错误提示，因为这是用户主动行为
          } else {
            console.error("选择图片失败:", error);
            uni.showToast({
              title: "选择图片失败",
              icon: "error",
            });
          }
        },
      });
    },

    // 上传图片
    async uploadImages(filePaths) {
      try {
        this.isLoading = true;

        const uploadPromises = filePaths.map((filePath) =>
          this.uploadSingleImage(filePath)
        );
        const results = await Promise.all(uploadPromises);

        // 过滤掉上传失败的图片
        const successResults = results.filter((result) => result.success);
        this.confirmImages.push(...successResults.map((result) => result.url));

        uni.showToast({
          title: `成功上传${successResults.length}张图片`,
          icon: "success",
        });
      } catch (error) {
        console.error("上传图片失败:", error);
        uni.showToast({
          title: "上传图片失败",
          icon: "error",
        });
      } finally {
        this.isLoading = false;
      }
    },

    // 上传单张图片
    uploadSingleImage(filePath) {
      return new Promise((resolve, reject) => {
        uni.uploadFile({
          url: `${this.$baseUrl}/campushelper/api/v1/upload/orderConfirm`,
          filePath: filePath,
          name: "file",
          header: {
            Authorization: `Bearer ${uni.getStorageSync("token")}`,
          },
          success: (res) => {
            try {
              const data = JSON.parse(res.data);
              if (data.success) {
                resolve({ success: true, url: data.data.url });
              } else {
                resolve({ success: false, error: data.message });
              }
            } catch (error) {
              resolve({ success: false, error: "解析响应失败" });
            }
          },
          fail: (error) => {
            resolve({ success: false, error: error.errMsg });
          },
        });
      });
    },

    // 预览图片
    previewImage(current) {
      uni.previewImage({
        urls: this.confirmImages,
        current: current,
      });
    },

    // 删除图片
    removeImage(index) {
      uni.showModal({
        title: "确认删除",
        content: "确定要删除这张图片吗？",
        success: (res) => {
          if (res.confirm) {
            this.confirmImages.splice(index, 1);
          }
        },
      });
    },
  },
};
</script>

