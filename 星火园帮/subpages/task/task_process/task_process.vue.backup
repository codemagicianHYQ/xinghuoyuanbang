<template>
  <view class="order-process-container">
    <!-- 状态对应的提示信息 -->
    <view class="status-section">
      <view class="status-card" :class="statusCardClass">
        <view class="status-icon">
          <uni-icons
            :type="statusIconType"
            size="48"
            :color="statusIconColor"
          ></uni-icons>
        </view>
        <text class="status-title">{{ statusTitle }}</text>
        <text class="status-desc">{{ statusDescription }}</text>
      </view>
    </view>

    <!-- 任务详情区块化布局 -->
    <view v-if="task" class="task-detail-container">
      <!-- 任务基本信息 -->
      <view class="task-basic-info">
        <view class="task-title-section">
          <text class="task-title">{{ task.title || "无标题" }}</text>
          <text class="task-reward">¥{{ getTaskAmount }}</text>
        </view>
        <view class="task-meta">
          <text class="task-type">{{ task.taskType }}</text>
          <view class="status-badge" :class="statusClass">{{
            statusText
          }}</view>
        </view>
        <text
          class="task-deadline"
          v-if="task.deadline && task.deadline !== 'null'"
          >{{ formatDeadline(task.deadline) }}截止</text
        >
      </view>

      <!-- 任务描述区块 -->
      <view class="task-description-block">
        <view class="block-icon">📝</view>
        <view class="block-content">
          <text class="block-title">任务描述</text>
          <text class="block-text">{{ taskDescription }}</text>
        </view>
      </view>

      <!-- 任务详情区块 -->
      <view v-if="task.specifics" class="task-details-block">
        <view class="block-icon">📋</view>
        <view class="block-content">
          <text class="block-title">任务详情</text>
          <text class="block-text">{{ formattedSpecifics }}</text>
        </view>
      </view>

      <!-- 任务地点区块 -->
      <view class="task-location-block">
        <view class="block-icon">📍</view>
        <view class="block-content">
          <text class="block-title">任务地点</text>
          <text class="block-text">{{ taskLocation }}</text>
        </view>
      </view>

      <!-- 备注信息区块 -->
      <view
        v-if="task.remarks && task.remarks.trim()"
        class="task-remarks-block"
      >
        <view class="block-icon">💬</view>
        <view class="block-content">
          <text class="block-title">备注信息</text>
          <text class="block-text">{{ task.remarks }}</text>
        </view>
      </view>

      <!-- 性别要求区块 -->
      <view
        v-if="task.requiredGender !== undefined && task.requiredGender !== 0"
        class="task-gender-block"
      >
        <view class="block-icon">👥</view>
        <view class="block-content">
          <text class="block-title">性别要求</text>
          <text class="block-text">{{
            getGenderText(task.requiredGender)
          }}</text>
        </view>
      </view>

      <!-- 订单信息区块 -->
      <view class="task-order-block">
        <view class="block-icon">📊</view>
        <view class="block-content">
          <text class="block-title">订单信息</text>
          <view class="order-info-list">
            <view class="order-info-item">
              <text class="order-label">单号</text>
              <text class="order-value">{{ orderNumber }}</text>
            </view>
            <view class="order-info-item">
              <text class="order-label">创建时间</text>
              <text class="order-value">{{ createTime }}</text>
            </view>
            <view class="order-info-item">
              <text class="order-label">接单时间</text>
              <text class="order-value">{{ acceptTime }}</text>
            </view>
            <view v-if="task.publisherConfirmedTime" class="order-info-item">
              <text class="order-label">完成时间</text>
              <text class="order-value">{{
                formatDateTime(task.publisherConfirmedTime)
              }}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 发布者信息 -->
    <view class="publisher-info">
      <view class="info-header">
        <text class="info-title">{{
          isPublisher ? "接单员信息" : "发布者信息"
        }}</text>
      </view>

      <view class="publisher-card">
        <image
          :src="isPublisher ? getAcceptorAvatar() : getPublisherAvatar()"
          class="publisher-avatar"
        />
        <view class="publisher-detail">
          <text class="publisher-name">{{
            isPublisher ? getAcceptorName() : getPublisherName()
          }}</text>
          <text class="publisher-desc">{{
            isPublisher ? "任务接单员" : "任务发布者"
          }}</text>
        </view>
        <button class="contact-btn" @click="contactPublisher">
          {{ isPublisher ? "联系接单员" : "联系发布者" }}
        </button>
      </view>
    </view>

    <!-- 操作指南 -->
    <view v-if="task && !isCompletedStatus" class="guide-section">
      <view class="info-header">
        <text class="info-title">操作指南</text>
      </view>

      <view class="guide-list">
        <view
          v-if="!isPublisher && task.status === 'assigned'"
          class="guide-item"
        >
          <view class="guide-icon">1</view>
          <view class="guide-content">
            <text class="guide-title">及时联系发布者</text>
            <text class="guide-desc">确认任务具体要求，避免误解</text>
          </view>
        </view>

        <view
          v-if="!isPublisher && task.status === 'assigned'"
          class="guide-item"
        >
          <view class="guide-icon">2</view>
          <view class="guide-content">
            <text class="guide-title">按时完成任务</text>
            <text class="guide-desc">在截止时间前完成，保持良好信誉</text>
          </view>
        </view>

        <view
          v-if="!isPublisher && task.status === 'assigned'"
          class="guide-item"
        >
          <view class="guide-icon">3</view>
          <view class="guide-content">
            <text class="guide-title">标记任务完成</text>
            <text class="guide-desc">完成后及时标记，等待发布者确认</text>
          </view>
        </view>

        <view
          v-if="isPublisher && task.status === 'assigned'"
          class="guide-item"
        >
          <view class="guide-icon">1</view>
          <view class="guide-content">
            <text class="guide-title">及时联系接单员</text>
            <text class="guide-desc">确认任务进度，提供必要帮助</text>
          </view>
        </view>

        <view
          v-if="isPublisher && task.status === 'acceptor_done'"
          class="guide-item"
        >
          <view class="guide-icon">1</view>
          <view class="guide-content">
            <text class="guide-title">确认任务完成</text>
            <text class="guide-desc">接单员已标记完成，请及时确认</text>
          </view>
        </view>

        <view
          v-if="isPublisher && task.status === 'acceptor_done'"
          class="guide-item"
        >
          <view class="guide-icon">2</view>
          <view class="guide-content">
            <text class="guide-title">评价服务</text>
            <text class="guide-desc">对服务进行评价，帮助其他用户</text>
          </view>
        </view>

        <view
          v-if="!isPublisher && task.status === 'acceptor_done'"
          class="guide-item"
        >
          <view class="guide-icon">1</view>
          <view class="guide-content">
            <text class="guide-title">等待发布者确认</text>
            <text class="guide-desc">您已标记完成，等待发布者确认</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 订单确认图片上传区域 -->
    <view
      v-if="!isPublisher && task && task.status === 'assigned'"
      class="confirm-images-card"
    >
      <text class="confirm-images-title">📷 上传完成凭证</text>
      <text class="confirm-images-desc">请上传任务完成凭证图片（可选）</text>

      <!-- 图片上传区域 -->
      <view class="upload-area">
        <view
          v-for="(image, index) in confirmImages"
          :key="index"
          class="image-item"
        >
          <image
            :src="image"
            class="uploaded-image"
            @click="previewImage(image)"
          />
          <view class="image-actions">
            <button class="delete-btn" @click="removeImage(index)">删除</button>
          </view>
        </view>

        <view
          v-if="confirmImages.length < maxImages"
          class="upload-btn"
          @click="chooseImage"
        >
          <text class="upload-icon">+</text>
          <text class="upload-text">添加图片</text>
        </view>
      </view>

      <text class="upload-tip">最多可上传 {{ maxImages }} 张图片</text>
    </view>

    <!-- 接单员底部操作按钮 -->
    <view
      v-if="!isPublisher && task && task.status === 'assigned'"
      class="fixed-bottom-actions"
    >
      <button
        class="reject-btn"
        @click="handleRejectClick"
        :class="{ disabled: !canRejectTask }"
      >
        {{ rejectButtonText }}
      </button>
      <button
        class="complete-btn"
        @click="markAsComplete"
        :loading="isLoading"
        :disabled="isLoading"
      >
        标记完成
      </button>
    </view>

    <!-- 发布者确认完成按钮 -->
    <button
      v-if="isPublisher && task && task.status === 'acceptor_done'"
      class="confirm-btn fixed-bottom-btn"
      @click="confirmTaskComplete"
      :loading="isConfirming"
      :disabled="isConfirming"
    >
      确认完成
    </button>

    <!-- 加载状态 -->
    <view v-if="isLoading" class="loading-overlay">
      <uni-load-more status="loading"></uni-load-more>
    </view>
  </view>
</template>

<script>
import request from "@/common/request.js";

export default {
  data() {
    return {
      taskId: null,
      task: null,
      isLoading: true,
      isCompleting: false,
      isConfirming: false, // 新增：用于控制确认完成按钮的加载状态
      confirmImages: [], // 确认图片数组
      maxImages: 3, // 最大图片数量
    };
  },
  computed: {
    statusText() {
      if (!this.task) return "";
      const statusMap = {
        open: "待接单",
        assigned: "进行中",
        acceptor_done: "待确认",
        publisher_confirmed: "已完成",
        completed: "已完成",
        cancelled: "已取消",
      };
      return statusMap[this.task.status] || "进行中";
    },
    statusClass() {
      if (!this.task) return "";
      const classMap = {
        open: "status-waiting",
        assigned: "status-doing",
        acceptor_done: "status-done",
        publisher_confirmed: "status-confirmed",
        completed: "status-done",
        cancelled: "status-cancelled",
      };
      return classMap[this.task.status] || "status-doing";
    },
    // 状态卡片样式
    statusCardClass() {
      if (!this.task) return "status-card-default";
      const classMap = {
        open: "status-card-waiting",
        assigned: "status-card-processing",
        acceptor_done: "status-card-waiting-confirm",
        publisher_confirmed: "status-card-completed",
        completed: "status-card-completed",
        cancelled: "status-card-cancelled",
      };
      return classMap[this.task.status] || "status-card-default";
    },
    // 状态图标类型
    statusIconType() {
      if (!this.task) return "info";
      const iconMap = {
        open: "info",
        assigned: "gear",
        acceptor_done: "clock",
        publisher_confirmed: "checkmarkempty",
        completed: "checkmarkempty",
        cancelled: "closeempty",
      };
      return iconMap[this.task.status] || "info";
    },
    // 状态图标颜色
    statusIconColor() {
      if (!this.task) return "#666";
      const colorMap = {
        open: "#666",
        assigned: "#007aff",
        acceptor_done: "#ff9500",
        publisher_confirmed: "#4ecb73",
        completed: "#4ecb73",
        cancelled: "#ff3b30",
      };
      return colorMap[this.task.status] || "#666";
    },
    // 状态标题
    statusTitle() {
      if (!this.task) return "加载中...";

      // 根据用户身份和任务状态显示不同标题
      if (this.isPublisher) {
        // 发布者视角
        const publisherTitleMap = {
          open: "订单待接单",
          assigned: "订单进行中",
          acceptor_done: "等待确认完成",
          publisher_confirmed: "订单已完成",
          completed: "订单已完成",
          cancelled: "订单已取消",
        };
        return publisherTitleMap[this.task.status] || "订单处理中";
      } else {
        // 接单员视角
        const riderTitleMap = {
          open: "订单已驳回",
          assigned: "接单成功！",
          acceptor_done: "等待发布者确认",
          publisher_confirmed: "任务已完成",
          completed: "任务已完成",
          cancelled: "订单已取消",
        };
        return riderTitleMap[this.task.status] || "订单处理中";
      }
    },
    // 状态描述
    statusDescription() {
      if (!this.task) return "正在加载订单信息...";

      // 根据用户身份和任务状态显示不同描述
      if (this.isPublisher) {
        // 发布者视角
        const publisherDescMap = {
          open: "等待接单员接取您的任务",
          assigned: "接单员正在处理您的任务，请保持联系",
          acceptor_done: "接单员已标记完成，请及时确认",
          publisher_confirmed: "任务已完成，款项已打给接单员",
          completed: "任务已完成，款项已打给接单员",
          cancelled: "订单已被取消",
        };
        return publisherDescMap[this.task.status] || "订单正在处理中";
      } else {
        // 接单员视角
        const riderDescMap = {
          open: "订单已返回订单大厅，等待其他接单员接取",
          assigned: "您已成功接取该任务，请及时处理",
          acceptor_done: "您已标记完成，等待发布者确认",
          publisher_confirmed: "任务已完成，款项已到账",
          completed: "任务已完成，款项已到账",
          cancelled: "订单已被取消",
        };
        return riderDescMap[this.task.status] || "订单正在处理中";
      }
    },
    isCompletedStatus() {
      return (
        this.task &&
        (this.task.status === "completed" ||
          this.task.status === "publisher_confirmed")
      );
    },
    currentUserInfo() {
      return this.$store.state.userInfo;
    },
    isRiderUser() {
      return (
        this.currentUserInfo &&
        (this.currentUserInfo.role === "rider" ||
          this.currentUserInfo.riderApplicationStatus === "approved")
      );
    },
    isPublisher() {
      return (
        this.currentUserInfo &&
        this.task &&
        this.task.publisherId === this.currentUserInfo.id
      );
    },
    // 任务描述计算属性
    taskDescription() {
      if (!this.task) return "请帮我取快递";


      // 如果有正常的描述内容
      if (
        this.task.description &&
        this.task.description !== null &&
        this.task.description !== "null" &&
        this.task.description.trim() &&
        !this.task.description.match(/^\d{4}-\d{2}-\d{2}/)
      ) {
        return this.cleanHtmlContent(this.task.description);
      }

      // 根据任务类型返回默认描述
      const taskType = this.task.taskType || "";
      switch (taskType) {
        case "取快递":
          return "请帮我取快递";
        case "取外卖":
          return "请帮我取外卖";
        case "搬运服务":
          return "请帮我搬运物品";
        case "找搭子":
          return "寻找活动搭子";
        case "帮我买":
          return "请帮我购买物品";
        case "借物品":
          return "请借我物品";
        case "代替服务":
          return "代替服务需求";
        case "课程代替":
          return "课程代替需求";
        case "求资料":
          return "求资料帮助";
        case "游戏陪玩":
          return "游戏陪玩需求";
        case "其他帮助":
          return "其他帮助需求";
        default:
          return "请帮我取快递";
      }
    },
    // 任务地点计算属性
    taskLocation() {
      if (!this.task) return "未知地点";

        "[taskLocation] 计算属性调用，task.locationText:",
        this.task.locationText
      );
        "[taskLocation] 计算属性调用，task.specifics:",
        this.task.specifics
      );

      const taskType = this.task.taskType || "";

      // 根据任务类型优化地点显示
      switch (taskType) {
        case "游戏开黑":
          return "线上游戏";

        case "搬运服务":
          // 解析具体信息，提取起始地点
          if (this.task.specifics) {
            const startLocationMatch = this.task.specifics.match(
              /起始地点[:：]\s*([^,，\n]+)/
            );
            if (startLocationMatch) {
              return startLocationMatch[1].trim();
            }
          }
          return this.task.locationText || "搬运地点";

        case "找搭子":
          // 解析具体信息，提取活动地点
          if (this.task.specifics) {
            const activityMatch = this.task.specifics.match(
              /活动地点[:：]\s*([^,，\n]+)/
            );
            if (activityMatch) {
              return activityMatch[1].trim();
            }
          }
          return this.task.locationText || "活动地点";

        case "分身服务":
          return "线上服务";

        case "分身服务":
          // 解析具体信息，提取上课地点
          if (this.task.specifics) {
            const classLocationMatch = this.task.specifics.match(
              /上课地点[:：]\s*([^,，\n]+)/
            );
            if (classLocationMatch) {
              return classLocationMatch[1].trim();
            }
          }
          // 如果是线上课程
          if (this.task.specifics && this.task.specifics.includes("线上")) {
            return "线上课程";
          }
          return this.task.locationText || "教学楼";

        case "取快递":
        case "取外卖":
          // 解析具体信息，提取送达地址
          if (this.task.specifics) {
            const deliveryMatch = this.task.specifics.match(
              /送达地址[:：]\s*([^,，\n]+)/
            );
            if (deliveryMatch) {
              return "送：" + deliveryMatch[1].trim();
            }
          }
          // 如果locationText为空或null，返回默认值
          if (
            this.task.locationText &&
            this.task.locationText !== "null" &&
            this.task.locationText.trim()
          ) {
            return "送：" + this.task.locationText;
          }
          return "杭州市滨江区"; // 默认地点

        case "帮我买":
          if (this.task.specifics) {
            const shopMatch = this.task.specifics.match(
              /购买地点[:：]\s*([^,，\n]+)/
            );
            if (shopMatch) {
              return shopMatch[1].trim();
            }
          }
          return this.task.locationText || "购买地点";

        case "借物品":
          // 解析具体信息，提取取货地点
          if (this.task.specifics) {
            const pickupMatch = this.task.specifics.match(
              /取货地点[:：]\s*([^,，\n]+)/
            );
            if (pickupMatch) {
              return pickupMatch[1].trim();
            }
          }
          return this.task.locationText || "取货地点";

        case "求资料":
          return "线上服务";

        case "其他帮助":
          return this.task.locationText || "待定地点";

        default:
          // 如果地点为空、null或只有空格，显示默认地点
          if (
            !this.task.locationText ||
            this.task.locationText === "null" ||
            this.task.locationText.trim() === "" ||
            this.task.locationText === "空"
          ) {
            return "杭州市滨江区";
          }
          return this.task.locationText;
      }
    },
    // 订单号计算属性
    orderNumber() {
      if (!this.task) return "暂未生成";

      // 对于借物品任务，检查是否为借出模式
      if (this.task.taskType === "借物品") {
        // 借出模式：如果任务还未被接单（状态为open），显示"借出后生成"
        if (this.task.borrowMode === "lend") {
          if (this.task.status === "open") {
            return "借出后生成";
          }
          // 如果已经被接单且有订单号，显示实际订单号
          if (this.task.out_trade_no) {
            return this.formatOrderNumber(this.task.out_trade_no);
          }
          return "借出后生成";
        }
        // 借进模式显示实际订单号
        if (this.task.borrowMode === "borrow" && this.task.out_trade_no) {
          return this.formatOrderNumber(this.task.out_trade_no);
        }
        return "借出后生成";
      }

      if (!this.task.out_trade_no) return "暂未生成";
      return this.formatOrderNumber(this.task.out_trade_no);
    },
    // 创建时间计算属性
    createTime() {
      if (!this.task || !this.task.createdAt) return "暂无";
        "[createTime] 计算属性调用，task.createdAt:",
        this.task.createdAt
      );
      return this.formatDateTime(this.task.createdAt);
    },
    // 接单时间计算属性
    acceptTime() {
      if (!this.task || !this.task.acceptedAt) return "暂无";
        "[acceptTime] 计算属性调用，task.acceptedAt:",
        this.task.acceptedAt
      );
      return this.formatDateTime(this.task.acceptedAt);
    },
    // 驳回按钮文本计算属性
    rejectButtonText() {
      if (!this.task) return "驳回订单";

        "[rejectButtonText] 计算属性调用，task.taskType:",
        this.task.taskType,
        "task.borrowMode:",
        this.task.borrowMode
      );

      if (this.task.taskType === "借物品") {
        if (this.task.borrowMode === "lend") {
          // 借出模式：借入者取消订单
          return "取消订单";
        } else if (this.task.borrowMode === "borrow") {
          // 借进模式：借出者驳回订单
          return "驳回订单";
        }
      }
      // 其他任务类型
      return "驳回订单";
    },
    formattedSpecifics() {
      if (!this.task || !this.task.specifics) return "";
      let specifics = this.task.specifics;

      // 对包裹大小进行中文翻译（如果需要）
      specifics = specifics
        .replace(/包裹大小: small/g, "包裹大小: 小件")
        .replace(/包裹大小: medium/g, "包裹大小: 中件")
        .replace(/包裹大小: large/g, "包裹大小: 大件");

      // 对于借物品任务，优先显示用户选择的借用时间
      if (this.task.taskType === "借物品") {
        // 检查是否有借用时间信息
        const borrowTimeMatch = specifics.match(/借用时间: (.+)/);
        if (borrowTimeMatch) {
          // 如果有借用时间，替换可用时间为借用时间
          specifics = specifics.replace(
            /可用时间: [^\n]+/,
            `借用时间: ${borrowTimeMatch[1]}`
          );
        }
      }

      return specifics;
    },

    // 检查是否可以驳回订单（接单后10分钟内）
    canRejectTask() {
      if (!this.task || !this.task.acceptedAt) {
        return false;
      }

      const acceptTime = new Date(this.task.acceptedAt);
      const currentTime = new Date();
      const timeDiff = currentTime - acceptTime;
      const tenMinutes = 10 * 60 * 1000; // 10分钟的毫秒数
      const minutes = Math.floor(timeDiff / (1000 * 60));


      return timeDiff <= tenMinutes;
    },

    // 获取任务金额
    getTaskAmount() {
      if (!this.task) return 0;

      // 对于借物品任务，计算实际支付金额（押金+租金）
      if (this.task.taskType === "借物品") {
        const specifics = this.task.specifics || "";

        // 解析押金
        const depositMatch = specifics.match(/押金[：:]\s*(\d+(?:\.\d+)?)元/);
        const deposit = depositMatch ? parseFloat(depositMatch[1]) : 0;

        // 解析日租金
        const rentMatch = specifics.match(/日租金[：:]\s*(\d+(?:\.\d+)?)元/);
        const dailyRent = rentMatch ? parseFloat(rentMatch[1]) : 0;

        // 解析借用天数
        let days = 1;
        const borrowTimeMatch = specifics.match(/借用时间: (.+)/);
        if (borrowTimeMatch) {
          const timeRange = borrowTimeMatch[1];
          const dateMatch = timeRange.match(
            /(\d{4}-\d{2}-\d{2})\s*至\s*(\d{4}-\d{2}-\d{2})/
          );
          if (dateMatch) {
            const startDate = new Date(dateMatch[1]);
            const endDate = new Date(dateMatch[2]);
            const diffTime = Math.abs(endDate - startDate);
            days = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;
          }
        }

        const totalRent = dailyRent * days;
        const totalAmount = deposit + totalRent;


        return totalAmount.toFixed(2);
      }

      // 其他任务类型直接返回rewardAmount
      const amount = this.task.rewardAmount || 0;
      return amount;
    },
  },
  async onLoad(options) {
    this.taskId = options.id;

    // 如果用户信息为空，尝试从store获取
    if (!this.userInfo) {
      try {
        await this.$store.dispatch("fetchCurrentUserInfo");
      } catch (error) {
        console.error("获取用户信息失败:", error);
      }
    }


    if (this.taskId) {
      this.fetchTaskDetail();
    } else {
      uni.showToast({ title: "无效的任务ID", icon: "none" });
      this.goBack();
    }
  },
  methods: {
    async fetchTaskDetail() {
      this.isLoading = true;
      try {

        const res = await request({
          url: `/tasks/${this.taskId}`,
          method: "GET",
        });

"[fetchTaskDetail] 获取到的任务详情:", res);
"[fetchTaskDetail] 任务描述字段:", res.description);
"[fetchTaskDetail] 任务详情字段:", res.specifics);
"[fetchTaskDetail] 任务地点字段:", res.locationText);
"[fetchTaskDetail] 任务截止时间字段:", res.deadline);
"[fetchTaskDetail] 发布者信息:", res.publisher);
"[fetchTaskDetail] 接单者信息:", res.acceptor);
"[fetchTaskDetail] 任务类型字段:", res.taskType);
"[fetchTaskDetail] 创建时间字段:", res.createdAt);
"[fetchTaskDetail] 接单时间字段:", res.acceptedAt);
"[fetchTaskDetail] 支付订单号字段:", res.out_trade_no);

        // 检查发布者和接单者信息
        if (res.publisher) {
"[fetchTaskDetail] 发布者详细信息:", {
            id: res.publisher.id,
            nickname: res.publisher.nickname,
            avatarUrl: res.publisher.avatarUrl,
          });
        } else {
"[fetchTaskDetail] 发布者信息为空");
        }

        if (res.acceptor) {
"[fetchTaskDetail] 接单者详细信息:", {
            id: res.acceptor.id,
            nickname: res.acceptor.nickname,
            avatarUrl: res.acceptor.avatarUrl,
          });
        } else {
"[fetchTaskDetail] 接单者信息为空");
        }

        this.task = res;

        // 强制更新Vue响应式数据
        this.$forceUpdate();

        // 使用Vue.set确保响应式更新
        this.$set(this, "task", res);

        // 更新本地状态
        if (this.task && this.task.status) {
"[fetchTaskDetail] 任务状态已更新:", this.task.status);
        }

        // 调试数据绑定
"[fetchTaskDetail] 设置后的task对象:", this.task);
          "[fetchTaskDetail] task.description:",
          this.task.description
        );
          "[fetchTaskDetail] task.locationText:",
          this.task.locationText
        );

        // 添加发布者身份判断的调试信息
"[fetchTaskDetail] 任务发布者ID:", this.task.publisherId);
          "[fetchTaskDetail] 当前用户ID:",
          this.currentUserInfo && this.currentUserInfo.id
        );
"[fetchTaskDetail] 是否为发布者:", this.isPublisher);
"[fetchTaskDetail] 任务状态:", this.task.status);
          "[fetchTaskDetail] 是否应该显示确认按钮:",
          this.isPublisher && this.task.status === "acceptor_done"
        );
      } catch (e) {
        console.error("[fetchTaskDetail] 获取任务详情失败:", e);
        uni.showToast({ title: "加载失败", icon: "none" });
        this.goBack();
      } finally {
        this.isLoading = false;
      }
    },
    formatDeadline(deadline) {
      try {
        if (!deadline || deadline === null || deadline === "null")
          return "无截止时间";
        const d = new Date(deadline);
        if (isNaN(d.getTime())) return "时间格式错误";
        return `${d.getFullYear()}-${(d.getMonth() + 1)
          .toString()
          .padStart(2, "0")}-${d.getDate().toString().padStart(2, "0")} ${d
          .getHours()
          .toString()
          .padStart(2, "0")}:${d.getMinutes().toString().padStart(2, "0")}`;
      } catch (error) {
        console.error("格式化截止时间错误:", error);
        return "时间格式错误";
      }
    },
    goBack() {
      uni.navigateBack();
    },
    async contactPublisher() {
      // 检查任务状态
      if (!this.task || !this.task.publisher) {
        uni.showToast({
          title: "任务信息不完整",
          icon: "none",
        });
        return;
      }

      // 如果用户信息为空，尝试重新获取
      if (!this.userInfo) {
"用户信息为空，尝试重新获取");
        try {
          await this.$store.dispatch("fetchCurrentUserInfo");
        } catch (error) {
          console.error("获取用户信息失败:", error);
        }
      }

      // 获取当前用户信息
      const currentUserInfo = this.userInfo || this.$store.state.userInfo;
"当前用户信息:", currentUserInfo);

      // 检查用户身份
      const isPublisher =
        currentUserInfo && this.task.publisherId === currentUserInfo.id;
      const isAcceptor =
        currentUserInfo && this.task.acceptorId === currentUserInfo.id;
      const isRider =
        currentUserInfo &&
        (currentUserInfo.role === "rider" ||
          currentUserInfo.riderApplicationStatus === "approved");

"用户身份检查:", {
        isPublisher,
        isAcceptor,
        isRider,
        currentUserId: currentUserInfo && currentUserInfo.id,
        publisherId: this.task.publisherId,
        acceptorId: this.task.acceptorId,
      });

      // 确定要联系的用户
      let otherUserId = null;
      let otherUserName = "";
      let chatTitle = "";

      if (isPublisher && this.task.acceptor) {
        // 发布者联系接单员
        otherUserId = this.task.acceptor.id;
        otherUserName = this.task.acceptor.nickname || "接单员";
        chatTitle = `联系接单员 - ${this.task.title}`;
      } else if (isAcceptor && this.task.publisher) {
        // 接单员联系发布者
        otherUserId = this.task.publisher.id;
        otherUserName = this.task.publisher.nickname || "发布者";
        chatTitle = `联系发布者 - ${this.task.title}`;
      } else {
        uni.showToast({
          title: "无法确定联系对象",
          icon: "none",
        });
        return;
      }

      // 跳转到聊天页面
      uni.navigateTo({
        url: `/pages/chat/chat?taskId=${
          this.taskId
        }&otherUserId=${otherUserId}&title=${encodeURIComponent(chatTitle)}`,
      });
    },
    // 接单员确认完成任务
    async markAsComplete() {
      try {
        // 请求订阅消息授权
        await this.requestNotificationAuth();

        this.isLoading = true;

        // 构建请求数据
        const requestData = {};
        if (this.confirmImages.length > 0) {
          requestData.confirmImages = this.confirmImages;
        }

`[markAsComplete] 发送请求数据:`, requestData);

        const response = await request({
          url: `/tasks/${this.taskId}/acceptor-confirm-done`,
          method: "POST",
          data: requestData,
        });

        if (response.message) {
          uni.showToast({
            title: response.message,
            icon: "success",
          });

          // 刷新任务信息
          await this.fetchTaskDetail();
        }
      } catch (error) {
        console.error("确认完成任务失败:", error);
        uni.showToast({
          title: error.message || "确认失败",
          icon: "none",
        });
      } finally {
        this.isLoading = false;
      }
    },

    // 处理取消/驳回按钮点击
    handleRejectClick() {
"[handleRejectClick] 按钮被点击");
"[handleRejectClick] canRejectTask:", this.canRejectTask);

      if (!this.canRejectTask) {
"[handleRejectClick] 超时，显示提示");
        uni.showToast({
          title: "接单超过10分钟，无法取消订单",
          icon: "none",
          duration: 2000,
        });
        return;
      }

"[handleRejectClick] 未超时，继续处理");
      this.rejectTask();
    },

    // 驳回订单
    async rejectTask() {
"[rejectTask] 驳回订单按钮被点击");
"[rejectTask] canRejectTask:", this.canRejectTask);
"[rejectTask] task:", this.task);

      // 显示确认对话框
      const isBorrowItemLend =
        this.task &&
        this.task.taskType === "借物品" &&
        this.task.borrowMode === "lend";
      const title = isBorrowItemLend ? "取消订单" : "驳回订单";
      const content = isBorrowItemLend
        ? "确认要取消此借物品订单吗？取消后押金和租金将原路退回。"
        : "确认要驳回此订单吗？驳回后订单将返回订单大厅，其他接单员可以重新接取。";
      const confirmText = isBorrowItemLend ? "确认取消" : "确认驳回";

      uni.showModal({
        title: title,
        content: content,
        confirmText: confirmText,
        cancelText: "取消",
        success: async (res) => {
          if (res.confirm) {
            try {
"[rejectTask] 用户确认驳回，开始调用API");
              this.isLoading = true;
              const response = await request({
                url: `/tasks/${this.taskId}/reject`,
                method: "POST",
              });

"[rejectTask] API响应:", response);

              if (response.message) {
                const successMessage = isBorrowItemLend
                  ? "订单已取消，押金和租金将原路退回"
                  : response.message;
                uni.showToast({
                  title: successMessage,
                  icon: "success",
                });

                // 刷新任务信息
                await this.fetchTaskDetail();

                // 延迟返回上一页
                setTimeout(() => {
                  uni.navigateBack();
                }, 1500);
              }
            } catch (error) {
              console.error("[rejectTask] 驳回订单失败:", error);
              uni.showToast({
                title: error.message || "驳回失败",
                icon: "none",
              });
            } finally {
              this.isLoading = false;
            }
          } else {
"[rejectTask] 用户取消驳回");
          }
        },
      });
    },

    // 发布者确认完成任务
