      try {
        // 请求订阅消息授权
        await this.requestNotificationAuth();

"[confirmTaskComplete] 开始确认任务完成");
"[confirmTaskComplete] 任务ID:", this.taskId);
          "[confirmTaskComplete] 当前用户信息:",
